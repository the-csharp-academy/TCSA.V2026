@using TCSA.V2026.Data.DTOs
@using TCSA.V2026.Helpers

<MudCard Class="@($"roadmap-stage-card {StageClass}")" Outlined="true" Elevation="0">
    <MudCardContent Class="roadmap-stage-content">
        <div class="roadmap-stage-header">
            <div>
                <MudText Typo="Typo.h6" Class="roadmap-stage-title">@StageName</MudText>
            </div>
            <div class="roadmap-stage-progress-copy">
                <MudText Typo="Typo.caption">@CompletedCount of @Tasks.Count complete</MudText>
                <MudProgressLinear Value="@CompletionPercentage" Rounded="true" Size="Size.Small" />
            </div>
        </div>

        <div class="roadmap-task-grid">
            @foreach (var task in Tasks)
            {
                <MudTooltip Text="@task.Tooltip">
                    <MudLink Class="roadmap-task-link" OnClick="@(() => HandleLinkClick(task))" Underline="Underline.None">
                        <div class="roadmap-task @(task.IsCompleted ? "roadmap-task-complete" : string.Empty)">
                            <div class="roadmap-task-icon-wrap">
                                <MudImage Src="@($"/img/icons/{task.IconUrl}")" Alt="@task.Name" Class="roadmap-task-icon" />
                                @if (task.IsCompleted)
                                {
                                    <span class="roadmap-task-check" aria-label="Completed">
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                                    </span>
                                }
                            </div>
                            <MudText Typo="Typo.caption" Class="roadmap-task-name">@task.Name</MudText>
                        </div>
                    </MudLink>
                </MudTooltip>
            }
        </div>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public List<RoadmapTask> Tasks { get; set; } = new List<RoadmapTask>();
    [Parameter] public string StageName { get; set; } = string.Empty;
    [Parameter] public string StageClass { get; set; } = string.Empty;
    [Inject] private IJSRuntime JS { get; set; }

    private int CompletedCount => Tasks.Count(task => task.IsCompleted);
    private double CompletionPercentage => Tasks.Count == 0 ? 0 : CompletedCount * 100d / Tasks.Count;

    private async Task HandleLinkClick(RoadmapTask task)
    {
        var url = RoadmapHelper.GetUrl(task);
        if (string.IsNullOrEmpty(url)) return;
        await JS.InvokeVoidAsync("window.open", url, "_blank", "noopener,noreferrer");
    }
}

<style>
    .roadmap-stage-card {
        --stage-accent: var(--mud-palette-primary);
        width: 100%;
        border-color: color-mix(in srgb, var(--stage-accent) 28%, var(--mud-palette-lines-default));
        border-left: 5px solid var(--stage-accent);
        border-radius: 16px;
        background: linear-gradient(110deg, color-mix(in srgb, var(--stage-accent) 7%, var(--mud-palette-surface)), var(--mud-palette-surface) 44%);
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
    }

    .roadmap-stage-content {
        padding: 1.2rem 1.35rem !important;
    }

    .roadmap-stage-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        padding-bottom: 1rem;
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--mud-palette-lines-default);
    }

    .roadmap-stage-title {
        font-weight: 750;
    }

    .roadmap-stage-progress-copy {
        width: min(220px, 42%);
        text-align: right;
    }

    .roadmap-stage-progress-copy .mud-progress-linear {
        margin-top: 0.35rem;
        color: var(--stage-accent);
    }

    .roadmap-task-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(112px, 1fr));
        gap: 0.75rem;
    }

    .roadmap-task-link {
        display: block;
        color: inherit !important;
    }

    .roadmap-task {
        height: 100%;
        min-height: 112px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        padding: 0.7rem 0.55rem;
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 12px;
        background: var(--mud-palette-surface);
        transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
    }

    .roadmap-task:hover {
        transform: translateY(-2px);
        border-color: color-mix(in srgb, var(--stage-accent) 55%, var(--mud-palette-lines-default));
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.1);
    }

    .roadmap-task-complete {
        background: color-mix(in srgb, var(--mud-palette-success) 7%, var(--mud-palette-surface));
    }

    .roadmap-task-icon-wrap {
        position: relative;
        width: 58px;
        height: 58px;
        display: grid;
        place-items: center;
    }

    .roadmap-task-icon {
        width: 56px;
        height: 56px;
        object-fit: contain;
    }

    .roadmap-task-check {
        position: absolute;
        right: -6px;
        bottom: -4px;
        width: 24px;
        height: 24px;
        display: grid;
        place-items: center;
        color: white;
        border: 2px solid var(--mud-palette-surface);
        border-radius: 50%;
        background: var(--mud-palette-success);
    }

    .roadmap-task-name {
        width: 100%;
        min-height: 2.4em;
        display: -webkit-box;
        overflow: hidden;
        text-align: center;
        line-height: 1.2;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
    }

    .custom-color-green { --stage-accent: #15803d; }
    .custom-color-olivegreen { --stage-accent: #647a2f; }
    .custom-color-yellow { --stage-accent: #c58b00; }
    .custom-color-orange { --stage-accent: #e36014; }
    .custom-color-red { --stage-accent: #cf3f46; }
    .custom-color-purple { --stage-accent: #7e4bc4; }
    .custom-color-brown { --stage-accent: #8b5e3c; }
    .custom-color-gray { --stage-accent: #667085; }
    .custom-color-blue { --stage-accent: #2563b8; }
    .custom-color-black { --stage-accent: #252936; }

    @@media (max-width: 600px) {
        .roadmap-stage-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .roadmap-stage-progress-copy {
            width: 100%;
            text-align: left;
        }

        .roadmap-task-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
</style>
