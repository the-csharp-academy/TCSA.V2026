<!DOCTYPE html>
@using TCSA.V2026.Data.Curriculum
@using TCSA.V2026.Data.Models

<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@MetaDescription" />
    <meta property="og:site_name" content="The C# Academy" />
    <meta property="og:title" content="@MetaTitle" />
    <meta property="og:description" content="@MetaDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="@OpenGraphType" />
    <meta property="og:image" content="@MetaImageUrl" />
    <meta property="og:image:alt" content="@MetaTitle" />

    <!-- Optional: Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@MetaTitle" />
    <meta name="twitter:description" content="@MetaDescription" />
    <meta name="twitter:image" content="@MetaImageUrl" />

    <!-- Google AdSense Verification -->
    @if (!IsAuthPage)
    {
        <meta name="google-adsense-account" content="ca-pub-4831088216810061">
        <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4831088216810061"
                crossorigin="anonymous"></script>
    }

   
    <!-- Canonical URL -->
    <link rel="canonical" href="@CanonicalUrl" />

    <base href="/" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="https://use.fontawesome.com/releases/v5.14.0/css/all.css" rel="stylesheet">
    <link href=@Assets["_content/MudBlazor/MudBlazor.min.css"] rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-okaidia.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/line-numbers/prism-line-numbers.min.css" rel="stylesheet" />
    <link href="css/site.css" rel="stylesheet" />
    <ImportMap />
    <link rel="icon" type="image/png" href="/img/logo.png" />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-csharp.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/line-numbers/prism-line-numbers.min.js"></script>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/shepherd.js@15.2.2/dist/css/shepherd.css" />
    <script>
        window.highlightCode = function () {
            Prism.highlightAll();
        };
    </script>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-TH8ERS2DZJ"></script>

    <script>
        window.dataLayer = window.dataLayer || [];

        function gtag() {
        dataLayer.push(arguments);
        }

        gtag('js', new Date());

        gtag('config', 'G-TH8ERS2DZJ');
    </script>
    <HeadOutlet @rendermode="RenderModeForPage" />
</head>

<body>
    <Routes @rendermode="RenderModeForPage" />
    <script src="_framework/blazor.web.js"></script>
    <script src=@Assets["_content/MudBlazor/MudBlazor.min.js"]></script>
    <script src=@Assets["_content/Extensions.MudBlazor.StaticInput/NavigationObserver.js"]></script>
    <script src="js/mentorship-scroll.js"></script>
    <script src="js/analytics.js"></script>
    <script src="js/ads.js"></script>
    <script>
        function setCookie(cname, cvalue, exdays) {
            const d = new Date();
            d.setTime(d.getTime() + (exdays*24*60*60*1000));
            let expires = "expires="+ d.toUTCString();
            document.cookie = cname + "=" + cvalue + ";" + expires + ";path=/";
        }

        function getCookie(name) {
            const cookies = document.cookie.split(';');
            for (let cookie of cookies) {
                const [key, value] = cookie.trim().split('=');
                if (key === name) return value;
            }
            return null;
        }
    </script>
</body>
</html>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private bool IsAuthPage;
    private const string SiteUrl = "https://thecsharpacademy.com";
    private string MetaTitle = "The C# Academy";
    private string MetaDescription = "Learn .NET/C# With Real Projects";
    private string MetaImageUrl = $"{SiteUrl}/img/logo.png";
    private string CanonicalUrl = $"{SiteUrl}/";
    private string OpenGraphType = "website";

    protected override void OnInitialized()
    {
        // Safe to read HttpContext here during the initial HTTP request
        if (HttpContext is not null)
        {
            var path = HttpContext.Request.Path;
            CanonicalUrl = $"{SiteUrl}{path.Value}";
             
            IsAuthPage = path.StartsWithSegments("/Account/Login", StringComparison.InvariantCultureIgnoreCase) ||
                          path.StartsWithSegments("/Account/Register", StringComparison.InvariantCultureIgnoreCase) ||
                          path.StartsWithSegments("/Account/LoginWith2fa", StringComparison.InvariantCultureIgnoreCase) ||
                          path.StartsWithSegments("/Account/LoginWithRecoveryCode", StringComparison.InvariantCultureIgnoreCase) ||
                          path.StartsWithSegments("/Account/ExternalLogin", StringComparison.InvariantCultureIgnoreCase) ||
                          path.StartsWithSegments("/Account/SignOut", StringComparison.InvariantCultureIgnoreCase);

            SetPageMetadata(path.Value ?? "/");
        }
    }

    private void SetPageMetadata(string path)
    {
        string[] segments = path.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);

        if (segments.Length >= 6 &&
            segments[0].Equals("course", StringComparison.OrdinalIgnoreCase) &&
            segments[2].Equals("article", StringComparison.OrdinalIgnoreCase) &&
            int.TryParse(segments[1], out int courseId) &&
            int.TryParse(segments[4], out int articleId))
        {
            Course? course = CourseHelper.GetCourses().FirstOrDefault(course => course.Id == courseId);
            Article? article = course?.Articles.FirstOrDefault(article => article.Id == articleId);

            if (course is not null && article is not null)
            {
                bool isCodePage = bool.TryParse(segments[5], out bool isCode) && isCode;
                MetaTitle = isCodePage
                    ? $"{article.Title} - Source Code | {course.Title}"
                    : $"{article.Title} | {course.Title}";
                MetaDescription = isCodePage
                    ? $"View the example source code for {article.Title} in {course.Title}."
                    : FirstNonEmpty(article.Description, course.Description, MetaDescription);
                MetaImageUrl = $"{SiteUrl}/img/icons/{course.ImgUrl}";
                OpenGraphType = "article";
                return;
            }
        }

        if (segments.Length >= 2 &&
            segments[0].Equals("project", StringComparison.OrdinalIgnoreCase) &&
            int.TryParse(segments[1], out int projectId))
        {
            Project? project = ProjectHelper.GetProjects().FirstOrDefault(project => project.Id == projectId);

            if (project is not null)
            {
                MetaTitle = $"{project.Title} | The C# Academy";
                MetaDescription = FirstNonEmpty(project.Description, MetaDescription);
                MetaImageUrl = $"{SiteUrl}/img/banners/{FirstNonEmpty(project.BannerUrl, "article-banner.jpg")}";
                OpenGraphType = "article";
                return;
            }
        }

        if (segments.Length >= 2 &&
            segments[0].Equals("article", StringComparison.OrdinalIgnoreCase) &&
            int.TryParse(segments[1], out int standaloneArticleId))
        {
            Article? article = ArticleHelper.GetArticles().FirstOrDefault(article => article.Id == standaloneArticleId);

            if (article is not null)
            {
                MetaTitle = $"{article.Title} | The C# Academy";
                MetaDescription = FirstNonEmpty(article.Description, MetaDescription);
                MetaImageUrl = article.Area == Area.Blog && !string.IsNullOrWhiteSpace(article.CardImgUrl)
                    ? $"{SiteUrl}/img/CardImages/{article.CardImgUrl}"
                    : $"{SiteUrl}/img/banners/{FirstNonEmpty(article.BannerUrl, "article-banner.jpg")}";
                OpenGraphType = "article";
                return;
            }
        }

        if (segments.Length >= 2 &&
            segments[0].Equals("articles", StringComparison.OrdinalIgnoreCase) &&
            segments[1].Equals("blog", StringComparison.OrdinalIgnoreCase))
        {
            Article? latestPost = BlogHelper.GetArticles()
                .OrderByDescending(article => article.ReleaseDate)
                .FirstOrDefault();

            MetaTitle = "The C# Academy Blog";
            MetaDescription = "Honest reflections on software development, learning, discipline, and building The C# Academy.";
            MetaImageUrl = latestPost is not null && !string.IsNullOrWhiteSpace(latestPost.CardImgUrl)
                ? $"{SiteUrl}/img/CardImages/{latestPost.CardImgUrl}"
                : $"{SiteUrl}/img/logo.png";
            return;
        }

        if (path.Equals("/dashboard/courses", StringComparison.OrdinalIgnoreCase))
        {
            MetaTitle = "C# Courses | The C# Academy";
            MetaDescription = "Learn C# through guided courses, practical explanations, exercises, and real applications.";
        }
    }

    private static string FirstNonEmpty(params string?[] values) =>
        values.First(value => !string.IsNullOrWhiteSpace(value))!;

    // Now this property safely reads a stable boolean variable and won't crash your live SignalR circuits
    private IComponentRenderMode? RenderModeForPage => IsAuthPage
        ? null
        : new InteractiveServerRenderMode(prerender: true);
}
