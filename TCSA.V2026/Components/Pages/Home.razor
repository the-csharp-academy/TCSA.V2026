@page "/"
@using TCSA.V2026.Data.Curriculum
@using TCSA.V2026.Data.DTOs
@using TCSA.V2026.Data.Models
@using TCSA.V2026.Helpers
@using TCSA.V2026.Services
<PageTitle>Home</PageTitle>

@if (IsLoading)
{
    <div class="loading-state">
        <MudProgressCircular Color="Color.Default" Indeterminate="true" Size="Size.Large" />
    </div>
}
else
{
    <div class="home-theme">
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-10 mb-10 hero-container">
        <MudPaper Class="pa-10 hero-paper" Elevation="6">
            <MudGrid>
                <MudItem xs="12" md="6" Class="responsive-center">
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Class="mb-4 hero-chip">Community-driven learning</MudChip>
                    <h1 class="responsive-banner mud-typography-h3 mud-primary-text hero-title">
                        Learn .NET/C# With Real Projects
                    </h1>
                    <MudText Class="mt-4 hero-subtitle">
                        Build real-world skills in .NET and C# through hands-on projects, guided practice, and expert mentoring. Our course is practical, engaging, and
                        <MudLink Href="https://exercism.org" Target="_blank">100% free, forever</MudLink>.
                    </MudText>

                    @if (!IsLoggedIn)
                    {
                        <MudStack Row="true" Spacing="2" Class="mt-6">
                            <MudButton OnClick="@(() => NavigateToRegistration())"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       EndIcon="@Icons.Material.Filled.ArrowForward">Sign up for free</MudButton>
                        </MudStack>
                    }
                </MudItem>

                <MudItem xs="12" md="6" Class="d-flex justify-center align-center">
                    <MudImage Src="img/banners/main-banner.gif"
                              Alt="Learn .NET with Projects"
                              Class="hero-image" />
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>

    @* <MudText>LoadTime: @LoadTime.TotalSeconds.ToString()</MudText> *@

    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-10 stats-container section-panel section-panel-soft">
        <div class="cards-grid">
            <div class="card-item">
                <MudPaper Class="px-4 py-2 d-flex flex-column align-center justify-center stat-card"
                          Style="max-width: 240px; width: 100%;"
                          Elevation="4">
                    <h2 class="mud-typography-h4 mud-primary-text mb-1">@Statistics.AllUsers</h2>
                    <div class="d-flex gap-1 align-center">
                        <MudText Typo="Typo.body2" Style="font-weight: bold">Users</MudText>
                    </div>
                </MudPaper>
            </div>
            <div class="card-item">
                <MudPaper Class="px-4 py-2 d-flex flex-column align-center justify-center stat-card"
                          Elevation="4">
                    <h2 class="mud-typography-h4 mud-primary-text mb-1">@Statistics.CurrentYearUsers</h2>
                    <div class="d-flex gap-1 align-center">
                        <MudText Typo="Typo.body2" Style="font-weight: bold">New Users @Statistics.CurrentYear</MudText>
                    </div>
                </MudPaper>
            </div>
           
            <div class="card-item">
                <MudPaper Class="px-4 py-2 d-flex flex-column align-center justify-center stat-card"
                          Elevation="4">
                    <h2 class="mud-typography-h4 mud-primary-text mb-1">@Statistics.AllReviewedProjects</h2>
                    <div class="d-flex gap-1 align-center">
                        <MudText Typo="Typo.body2" Style="font-weight: bold">Projects Reviewed</MudText>
                    </div>
                </MudPaper>
            </div>
            <div class="card-item">
                <MudPaper Class="px-4 py-2 d-flex flex-column align-center justify-center stat-card"
                          Elevation="4">
                    <h2 class="mud-typography-h4 mud-primary-text mb-1">@Statistics.CurrentYearReviewedProjects</h2>
                    <div class="d-flex gap-1 align-center">
                        <MudText Typo="Typo.body2" Style="font-weight: bold">Projects Reviewed @Statistics.CurrentYear</MudText>
                    </div>
                </MudPaper>
            </div>
            <div class="card-item">
                <MudPaper Class="px-4 py-2 d-flex flex-column align-center justify-center stat-card"
                          Elevation="4">
                    <h2 class="mud-typography-h4 mud-primary-text mb-1">@TimeSpanFormatter.FormatReviewTime(Statistics.AverageReviewTime)</h2>
                    <div class="d-flex gap-1 align-center">
                        <MudText Typo="Typo.body2" Style="font-weight: bold">Avg Review Time (30d)</MudText>
                    </div>
                </MudPaper>
            </div>
        </div>
    </MudContainer>

    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-10 section-panel section-panel-soft">
        <h2 class="mud-typography-h4 mud-primary-text mud-typography-align-center mb-2"
            style="font-weight: 500;"
            >
            First Steps
        </h2>

        <MudText Typo="Typo.subtitle1"
                 Align="Align.Center"
                 Class="mb-6 text-secondary section-intro">
            Get started with our program by reading and following the instructions in these articles.
            If possible, follow them in order. They cover everything you need to prepare for your C# journey.
        </MudText>

        <div class="cards-grid mt-5">
            @foreach (var article in Articles.Where(x => x.Area == Area.StartHere && x.Id != 9)) // not showing "Console App" Article
            {
                <div class="card-item">
                    <div class="clickable-card" @onclick="() => NavigateToArticle(article, false)">
                        <MudCard Style="height: 100%;" Elevation="4" Class="hover-expand home-card">
                            <MudCardContent Class="d-flex justify-center mt-4 flex-grow-0">
                                <MudImage Src="@($"img/icons/{article.IconUrl}")"
                                          Alt="@article.Title"
                                          Style="width: 100px; height: 100px; object-fit: cover;" />
                            </MudCardContent>
                            <MudCardContent Class="mb-5">
                                <h3 class="mud-typography-h5 mud-primary-text mud-typography-align-center mb-3">
                                    @article.Title
                                </h3>
                                <MudText Class="mb-10" Typo="Typo.body2">@article.Description</MudText>
                            </MudCardContent>
                        </MudCard>
                    </div>
                </div>
            }
        </div>
    </MudContainer>

    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-10 section-panel section-panel-soft">
        <h2 class="mud-typography-h4 mud-primary-text mud-typography-align-center mb-2 mt-5"
            style="font-weight: 500;">
            Console Apps
        </h2>
        <div class="cards-grid mt-3">
            @foreach (var p in Projects.Where(x => x.Area == Area.Console && x.Id != 52 && x.Id != 75))
            {
                <div class="card-item">
                    <div class="clickable-card" @onclick="() => NavigateToArticle(p, true)">
                        <MudCard Style="height: 100%;" Elevation="4" Class="hover-expand home-card">
                            <MudCardContent Class="d-flex justify-center mt-4 flex-grow-0">
                                <MudImage Src="@($"img/icons/{p.IconUrl}")"
                                          Alt="@p.Title"
                                          Style="width: 100px; height: 100px; object-fit: cover;" />
                            </MudCardContent>
                            <MudCardContent>
                                <h3 class="mud-typography-h5 mud-primary-text mud-typography-align-center mb-3">
                                    @p.Title
                                </h3>
                                <MudText Align="Align.Center"
                                         Class="mb-10"
                                         Typo="Typo.body2">@p.Description</MudText>
                            </MudCardContent>
                        </MudCard>
                    </div>
                </div>
            }
        </div>
    </MudContainer>

    @foreach (var a in Areas)
    {
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-12 section-panel section-panel-soft area-section" id="@a.Id">
            <div class="area-title-wrap">
                @if (!string.IsNullOrEmpty(a.TitleImgUrl))
                {
                    <MudImage Src="@($"img/titles/{a.TitleImgUrl}")"
                              Alt="@a.Area.ToString()"
                              Style="width: 50px; height: 50px; object-fit: cover;" />
                }
                <h2 class="mud-typography-h4 mud-primary-text">
                    @a.Title
                </h2>
            </div>

            <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-6 text-secondary">
                @a.Description
            </MudText>

            <div class="cards-grid mt-5">
                @foreach (var p in a.Projects)
                {
                    <div class="card-item">
                        <div class="clickable-card" @onclick="() => NavigateToArticle(p, true)">
                            <MudCard Style="height: 100%;" Elevation="4" Class="hover-expand home-card">
                                <MudCardContent Class="d-flex justify-center mt-4 flex-grow-0">
                                    <MudImage Src="@($"img/icons/{p.IconUrl}")"
                                              Alt="@p.Title"
                                              Style="width: 100px; height: 100px; object-fit: cover;" />
                                </MudCardContent>

                                <MudCardContent Class="flex-grow-1 d-flex flex-column justify-between">
                                    <h3 class="mud-typography-h5 mud-primary-text mud-typography-align-center mb-3">
                                        @p.Title
                                    </h3>
                                    <MudText Class="mb-10" Typo="Typo.body2">@p.Description</MudText>
                                </MudCardContent>
                            </MudCard>
                        </div>
                    </div>
                }
            </div>
        </MudContainer>
    }
    </div>

}

@code {
    [Inject] private AuthenticationStateProvider AuthenticationState { get; set; }
    [Inject] private NavigationManager Navigation { get; set; }
    [Inject] private IStatisticsService StatisticsService { get; set; } = default!;

    protected List<Project> Projects = new();
    protected List<Article> Articles = new();
    protected List<IndexAreaInfo> Areas = new();
    protected Project CertificationProject = new();
    protected Article ConsoleArticle = new();
    protected Article GraduationArticle = new();
    protected HomePageStatistics Statistics;

    private TimeSpan LoadTime = TimeSpan.Zero;
    private bool IsLoading = true;
    private bool IsLoggedIn = false;

    protected override async Task OnInitializedAsync()
    {
        var startTime = DateTime.UtcNow;

        Articles = ArticleHelper.GetArticles();
        Projects = ProjectHelper.GetProjects();
        CertificationProject = Projects.Single(x => x.Id == (int)ArticleName.FreecodeCamp);
        ConsoleArticle = Articles.Single(x => x.Id == (int)ArticleName.ImportanceOfConsole);
        GraduationArticle = Articles.Single(x => x.Id == (int)ArticleName.ConsoleGraduation);

        GetAreas();

        LoadTime = DateTime.UtcNow - startTime;

        Statistics = await StatisticsService.GetHomePageStatisticsAsync();
        var AuthSate = await AuthenticationState.GetAuthenticationStateAsync();
        IsLoading = false;

        if (AuthSate.User.Identity.IsAuthenticated)
        {
            IsLoggedIn = true;
        }

        IsLoading = false;
    }

    private void GetAreas()
    {
        var areas = new List<Area> { 
            Area.StartApplying, 
            Area.MVC, 
            Area.Angular, 
            Area.React, 
            Area.Blazor, 
            Area.MAUI, 
            Area.Auth, 
            Area.Azure, 
            Area.SQL, 
            Area.Docker,
            Area.GraduationProject, 
            Area.MonthlyChallenge, 
            Area.FreestyleProject };

        var titlePics = new List<string>
        {
            "apply-title.png",
            "mvc-title.png",
            "angular-title.png",
            "react-title.png",
            "blazor-title.png",
            "maui-title.png",
            "aa-title.png",
            "azure-title.png",
            "sql-title.png",
            string.Empty,
            string.Empty,
            string.Empty,
            string.Empty
        };
        var titles = new List<string>
        {
            "Apply for Jobs",
            "ASP.NET Core MVC",
            "Angular",
            "React",
            "Blazor",
            "MAUI",
            "Authorization and Authentication",
            "Azure",
            "SQL",
            "Docker",
            "Graduation Projects",
            "Challenge Projects",
            "Freestyle Projects"
        };

        var descriptions = new List<string>
        {
            "With these projects, you'll showcase your work and start applying for jobs.",
            "Learn the fundamentals of ASP.NET MVC",
            "Learn how .NET works together with this powerful front-end framework",
            "Learn how .NET works together with this powerful front-end framework",
            "Learn the latest .NET solution for web development",
            "Learn this fantastic technology to build apps for Android, iOS, MacOs and Windows.",
            "Learn to secure applications using .NET/C#",
            "Get started in cloud computing deploying applications to Microsoft's state-of-the-art cloud solution.",
            "Learn the language used to communicate with databases.",
            "Learn to package your app into a portable container that runs anywhere",
            "Transfer all your acquired knowledge to build and showcase an impressive application.",
            "Test your knowledge with a challenge provided by a real-world company given to job candidates.",
            "Bring your amazing idea to life with a professional standard project."
        };

        var ids = new List<string>
        {
            "jobs-area",
            "mvc-area",
            "angular-area",
            "react-area",
            "blazor-area",
            "maui-area",
            "auth-area",
            "cloud-area",
            "sql-area",
            "docker-area",
            "flagship-area",
            "challenges-area",
            "freestyle"
        };

        for (int i = 0; i < areas.Count; i++)
        {
            Areas.Add(new IndexAreaInfo
                {
                    Projects = areas[i] == Area.SQL
                    ? Projects.Where(x => x.Area == areas[i] && !x.IsClosed).ToList()
                    : Projects.Where(x => x.Area == areas[i])
                    .ToList(),
                    TitleImgUrl = titlePics[i],
                    Title = titles[i],
                    Description = descriptions[i],
                    Id = ids[i]
                });
        }
    }

    private Task NavigateToArticle(Article article, bool isProject)
    {
        var path = isProject ? "project" : "article";
        Navigation.NavigateTo($"/{path}/{article.Id}/{article.Slug}");
        return Task.CompletedTask;
    }

    private Task NavigateToRegistration()
    {
        Navigation.NavigateTo($"Account/Register", forceLoad: true);
        return Task.CompletedTask;
    }
}

<style>
    .home-theme {
        position: relative;
        isolation: isolate;
        padding-bottom: 2rem;
        overflow-x: hidden;
    }

        .home-theme::before,
        .home-theme::after {
            content: "";
            position: absolute;
            width: 460px;
            height: 460px;
            border-radius: 50%;
            z-index: -1;
            filter: blur(80px);
            opacity: 0.18;
            pointer-events: none;
        }

        .home-theme::before {
            top: 140px;
            right: -160px;
            background: rgba(var(--mud-palette-primary-rgb), 0.65);
        }

        .home-theme::after {
            top: 920px;
            left: -200px;
            background: rgba(var(--mud-palette-secondary-rgb), 0.55);
        }

    .loading-state {
        min-height: 40vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .hero-container {
        position: relative;
    }

    .hero-paper {
        border-radius: 24px;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.2);
        background: linear-gradient(140deg, rgba(var(--mud-palette-surface-rgb), 0.95) 0%, rgba(var(--mud-palette-primary-rgb), 0.08) 100%);
    }

        .hero-paper::after {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top right, rgba(var(--mud-palette-secondary-rgb), 0.13), transparent 46%);
            pointer-events: none;
        }

    .hero-chip {
        font-weight: 600;
        backdrop-filter: blur(3px);
    }

    .hero-title {
        line-height: 1.2;
    }

    .hero-subtitle {
        max-width: 620px;
    }

    .hero-image {
        max-width: 74%;
        height: auto;
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.18);
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.24);
    }

    .clickable-card {
        cursor: pointer;
        width: 100%;
        height: 100%;
    }

    .hover-expand {
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

        .hover-expand:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 24px rgba(0,0,0,0.2);
        }

    .home-card {
        border: 1px solid rgba(0,0,0,0.06);
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(var(--mud-palette-surface-rgb), 1) 0%, rgba(var(--mud-palette-primary-rgb), 0.04) 100%);
    }

        .home-card:hover {
            border-color: rgba(var(--mud-palette-primary-rgb), 0.35);
        }

    .section-panel {
        padding: 1.2rem 1rem;
        border-radius: 22px;
    }

    .section-panel-soft {
        border: 1px solid rgba(var(--mud-palette-lines-default-rgb), 0.55);
        background: linear-gradient(180deg, rgba(var(--mud-palette-surface-rgb), 0.94) 0%, rgba(var(--mud-palette-secondary-rgb), 0.05) 100%);
        box-shadow: 0 14px 34px rgba(0,0,0,0.08);
    }

    .section-intro {
        max-width: 760px;
        margin-inline: auto;
    }

    .area-title-wrap {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
    }

    .area-section {
        position: relative;
    }

        .area-section::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, rgba(var(--mud-palette-primary-rgb), 0.02), transparent 35%, rgba(var(--mud-palette-secondary-rgb), 0.04));
            border-radius: 22px;
            pointer-events: none;
        }

    .stats-container .cards-grid {
        gap: 1rem;
    }

    .stat-card {
        border-radius: 14px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.14);
        background: linear-gradient(165deg, rgba(var(--mud-palette-surface-rgb), 1) 0%, rgba(var(--mud-palette-info-rgb), 0.08) 100%);
    }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 22px rgba(0,0,0,0.18);
        }

    .stats-container .card-item:nth-child(2n) .stat-card {
        background: linear-gradient(165deg, rgba(var(--mud-palette-surface-rgb), 1) 0%, rgba(var(--mud-palette-secondary-rgb), 0.09) 100%);
        border-color: rgba(var(--mud-palette-secondary-rgb), 0.2);
    }

    .stats-container .card-item:nth-child(3n) .stat-card {
        background: linear-gradient(165deg, rgba(var(--mud-palette-surface-rgb), 1) 0%, rgba(var(--mud-palette-success-rgb), 0.09) 100%);
        border-color: rgba(var(--mud-palette-success-rgb), 0.22);
    }

    .cards-grid {
        display: grid;
        gap: 1.5rem;
        grid-template-columns: repeat(auto-fit, 200px);
        justify-content: center;
    }

    .grid-item, .card-item {
        width: 100%;
    }

    .card-item {
        display: flex;
        flex-direction: column;
    }

    @@media (max-width: 960px) {
        .section-panel {
            padding: 1rem 0.75rem;
            border-radius: 18px;
        }

        .hero-paper {
            border-radius: 20px;
        }

        .home-theme::before,
        .home-theme::after {
            width: 320px;
            height: 320px;
            filter: blur(65px);
        }

        .hero-image {
            max-width: 85%;
        }
    }
</style>
