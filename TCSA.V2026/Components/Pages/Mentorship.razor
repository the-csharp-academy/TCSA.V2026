@page "/mentorship"
@using Microsoft.Extensions.Options
@using TCSA.V2026.Data.Models
@using TCSA.V2026.Data.Models.Options
@rendermode RenderMode.InteractiveServer
@inject IOptions<LinksOptions> LinkOptions
<PageTitle>1-on-1 Mentorship - The C# Academy</PageTitle>

<div class="mentorship-page">
    <!-- Hero Section -->
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-10 mb-10">
        <MudPaper Class="pa-10 mentorship-hero" Elevation="8">
            <MudGrid Spacing="3">
                <MudItem xs="12" md="6" Class="d-flex flex-column justify-center">
                    <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Class="mb-4 mentorship-chip">Personalized Learning</MudChip>
                    <h1 class="mentorship-title mud-typography-h2">
                        Level Up Your Skills With Personalized 1-on-1 Mentorship
                    </h1>
                    <MudText Class="mt-4 mentorship-subtitle mud-typography-body1" Style="opacity: 0.95;">
                        Get expert guidance tailored to your goals. Whether you're starting your C# journey or mastering advanced concepts, we're here to accelerate your growth.
                    </MudText>

                    <MudStack Row="true" Spacing="3" Class="mt-8">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   Class="mentorship-subscribe-btn"
                                   OnClick="@ScrollToSubscribe">
                            Subscribe Now
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   EndIcon="@Icons.Material.Filled.CalendarToday"
                                   Href="https://calendly.com" Target="_blank">
                            View Calendar
                        </MudButton>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" md="6" Class="d-flex justify-center align-center">
                    <MudPaper Class="mentorship-hero-visual" Elevation="0">
                        <div class="hero-icon-container">
                            <MudIcon Icon="@Icons.Material.Filled.School" Class="mentorship-hero-icon"></MudIcon>
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>

    <!-- Cards Section -->
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-15 mb-10">
        <div class="cards-section">
            <MudText Typo="Typo.h4" Class="mb-8 text-center fw-bold">
                Learn More About Our Mentorship
            </MudText>

            <MudGrid Spacing="3">
                <MudItem xs="12" md="4">
                    <MudPaper Class="mentorship-card" Elevation="6">
                        <MudCardContent>
                            <div class="card-icon-wrapper bg-info">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Class="card-icon"></MudIcon>
                            </div>
                            <MudText Typo="Typo.h6" Class="mt-4 mb-3">Meet Your Mentor</MudText>
                            <MudText Typo="Typo.body2" Style="color: #666;">
                                Get to know the mentor who will guide your learning, review your code, and help you stay focused on the next right step.
                            </MudText>
                            <MudButton Variant="Variant.Text" Color="Color.Info" Class="mt-4 px-0" Href="/mentorship#meet-your-mentor">
                                Learn More <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="ms-2"></MudIcon>
                            </MudButton>
                        </MudCardContent>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="mentorship-card" Elevation="6">
                        <MudCardContent>
                            <div class="card-icon-wrapper bg-primary">
                                <MudIcon Icon="@Icons.Material.Filled.Timeline" Class="card-icon"></MudIcon>
                            </div>
                            <MudText Typo="Typo.h6" Class="mt-4 mb-3">How It Works</MudText>
                            <MudText Typo="Typo.body2" Style="color: #666;">
                                Discover our structured mentorship approach: one-on-one sessions, goal-setting, progress tracking, and continuous support tailored to your learning pace.
                            </MudText>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Class="mt-4 px-0" Href="/mentorship#how-it-works">
                                Learn More <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="ms-2"></MudIcon>
                            </MudButton>
                        </MudCardContent>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="mentorship-card" Elevation="6">
                        <MudCardContent>
                            <div class="card-icon-wrapper bg-success">
                                <MudIcon Icon="@Icons.Material.Filled.Groups" Class="card-icon"></MudIcon>
                            </div>
                            <MudText Typo="Typo.h6" Class="mt-4 mb-3">Who Is It For</MudText>
                            <MudText Typo="Typo.body2" Style="color: #666;">
                                Perfect for beginners starting their C# journey, career-changers, professionals aiming to advance their skills, and anyone seeking personalized guidance.
                            </MudText>
                            <MudButton Variant="Variant.Text" Color="Color.Success" Class="mt-4 px-0" Href="/mentorship#audience-tracks">
                                See If It Fits <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="ms-2"></MudIcon>
                            </MudButton>
                        </MudCardContent>
                    </MudPaper>
                </MudItem>
              
            </MudGrid>
        </div>
    </MudContainer>

    <!-- Mentor Section -->
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-15 mb-10">
        <MudPaper id="meet-your-mentor" Class="mentor-profile-section pa-8 pa-md-12" Elevation="8">
            <MudGrid Spacing="4" Class="mentor-profile-grid">
                <MudItem xs="12" md="7">
                    <MudChip T="string" Class="mentor-chip mb-4" Variant="Variant.Filled">
                        Meet your mentor
                    </MudChip>
                    <MudText Typo="Typo.h2" Class="mentor-title mb-4">
                        Hi, I'm Pablo.
                    </MudText>
                    <MudText Typo="Typo.h6" Class="mentor-subtitle mb-6">
                        I'm a software developer based in Brisbane, Australia, with 7 years of coding behind me and 5 years of professional experience building real systems for real teams.
                    </MudText>
                    <MudStack Row="true" Spacing="2" Class="mentor-actions" AlignItems="AlignItems.Center">
                        <MudButton Variant="Variant.Filled"
                                   Class="linkedin-button"
                                   StartIcon="@Icons.Custom.Brands.LinkedIn"
                                   Href="@LinkedinUrl"
                                   Target="_blank"
                                   Disabled="@string.IsNullOrWhiteSpace(LinkedinUrl)">
                            LinkedIn
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Class="mentor-outline-button"
                                   StartIcon="@Icons.Material.Filled.Route"
                                   Href="/mentorship#how-it-works">
                            How It Works
                        </MudButton>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" md="5">
                    <div class="mentor-card">
                        <div class="mentor-avatar">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Class="mentor-avatar-icon"></MudIcon>
                        </div>
                        <MudText Typo="Typo.h5" Class="mentor-name">Pablo</MudText>
                        <MudText Typo="Typo.body1" Class="mentor-location">
                            Brisbane, Australia
                        </MudText>
                        <div class="mentor-tags">
                            <span>C#</span>
                            <span>Mentorship</span>
                            <span>Career growth</span>
                        </div>
                    </div>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="mentor-guarantee-panel pa-6 mt-8" Elevation="6">
            <div class="mentor-guarantee-icon-wrap">
                <MudIcon Icon="@Icons.Material.Filled.Savings" Class="mentor-guarantee-icon"></MudIcon>
            </div>
            <div>
                <MudText Typo="Typo.h4" Class="mentor-guarantee-title mb-2">
                    Money Back Guarantee
                </MudText>
                <MudText Typo="Typo.body1" Class="mentor-guarantee-copy">
                    If you do not see results in your first month, you get your money back. The goal is simple: visible progress, better code, and a clearer path forward.
                </MudText>
            </div>
        </MudPaper>

        <MudGrid Spacing="3" Class="mt-8">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="mentor-stat stat-coral" Elevation="4">
                    <MudIcon Icon="@Icons.Material.Filled.Code" Class="stat-icon"></MudIcon>
                    <MudText Typo="Typo.h4" Class="stat-number">7</MudText>
                    <MudText Typo="Typo.body2">years coding</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="mentor-stat stat-blue" Elevation="4">
                    <MudIcon Icon="@Icons.Material.Filled.Work" Class="stat-icon"></MudIcon>
                    <MudText Typo="Typo.h4" Class="stat-number">5</MudText>
                    <MudText Typo="Typo.body2">years professional</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="mentor-stat stat-green" Elevation="4">
                    <MudIcon Icon="@Icons.Material.Filled.Storefront" Class="stat-icon"></MudIcon>
                    <MudText Typo="Typo.h4" Class="stat-number">1</MudText>
                    <MudText Typo="Typo.body2">year at EB Games</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="mentor-stat stat-gold" Elevation="4">
                    <MudIcon Icon="@Icons.Material.Filled.BusinessCenter" Class="stat-icon"></MudIcon>
                    <MudText Typo="Typo.h4" Class="stat-number">4</MudText>
                    <MudText Typo="Typo.body2">years at Business Automation Works</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudGrid id="audience-tracks" Spacing="4" Class="mt-8">
            <MudItem xs="12" md="6">
                <MudPaper Class="mentor-panel pa-6" Elevation="5">
                    <MudText Typo="Typo.h5" Class="mentor-section-title mb-4">Where I've Worked</MudText>
                    <div class="timeline">
                        <div class="timeline-item">
                            <span class="timeline-dot dot-green"></span>
                            <div>
                                <MudText Typo="Typo.h6">EB Games</MudText>
                                <MudText Typo="Typo.body2">1 year of professional coding experience in a fast-moving retail technology environment.</MudText>
                            </div>
                        </div>
                        <div class="timeline-item">
                            <span class="timeline-dot dot-blue"></span>
                            <div>
                                <MudText Typo="Typo.h6">Business Automation Works</MudText>
                                <MudText Typo="Typo.body2">4 years building, maintaining, and improving business software with practical outcomes in mind.</MudText>
                            </div>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="mentor-panel pa-6 mentor-style-panel" Elevation="5">
                    <MudText Typo="Typo.h5" Class="mentor-section-title mb-4">How I Mentor</MudText>
                    <MudText Typo="Typo.body1" Class="mb-4">
                        My goal is to make programming feel less mysterious and more manageable. We'll focus on practical code, clear next steps, and the habits that help you keep improving after each session.
                    </MudText>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <div class="mentor-principle">
                                <MudIcon Icon="@Icons.Material.Filled.Route" />
                                <span>Clear learning path</span>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <div class="mentor-principle">
                                <MudIcon Icon="@Icons.Material.Filled.RateReview" />
                                <span>Helpful code reviews</span>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <div class="mentor-principle">
                                <MudIcon Icon="@Icons.Material.Filled.Psychology" />
                                <span>Problem-solving practice</span>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <div class="mentor-principle">
                                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" />
                                <span>Career-minded guidance</span>
                            </div>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>

    <!-- How It Works Section -->
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-15 mb-10">
        <MudPaper id="how-it-works" Class="mentor-how-panel pa-8" Elevation="6">
            <MudGrid Spacing="4" Class="mentor-how-grid">
                <MudItem xs="12" md="7">
                    <MudChip T="string" Class="mentor-how-chip mb-4" Variant="Variant.Filled">
                        How it works
                    </MudChip>
                    <MudText Typo="Typo.h3" Class="mentor-how-title mb-4">
                        Clear goals, close feedback, real software work.
                    </MudText>
                    <MudText Typo="Typo.body1" Class="mentor-how-copy">
                        The program adapts to your level. Beginners close knowledge gaps and follow the roadmap with regular code reviews. Experienced developers build a professional project and contribute to The C# Academy like a junior dev on a production team.
                    </MudText>
                </MudItem>
                <MudItem xs="12" md="5">
                    <div class="mentor-how-summary">
                        <div class="mentor-how-summary-row">
                            <MudIcon Icon="@Icons.Material.Filled.Map"></MudIcon>
                            <span>Personal roadmap</span>
                        </div>
                        <div class="mentor-how-summary-row">
                            <MudIcon Icon="@Icons.Material.Filled.RateReview"></MudIcon>
                            <span>Close code reviews</span>
                        </div>
                        <div class="mentor-how-summary-row">
                            <MudIcon Icon="@Icons.Material.Filled.RocketLaunch"></MudIcon>
                            <span>Professional project delivery</span>
                        </div>
                        <div class="mentor-how-summary-row">
                            <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn"></MudIcon>
                            <span>Production tickets in The C# Academy</span>
                        </div>
                    </div>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudGrid Spacing="4" Class="mt-8">
            <MudItem xs="12" md="6">
                <MudPaper Class="track-card beginner-track pa-6" Elevation="5">
                    <div class="track-icon">
                        <MudIcon Icon="@Icons.Material.Filled.School"></MudIcon>
                    </div>
                    <MudText Typo="Typo.h4" Class="track-title mb-3">For Beginners</MudText>
                    <MudText Typo="Typo.body1" Class="track-copy mb-5">
                        We'll identify what is missing, close the gaps, and follow The C# Academy roadmap at a pace that keeps you moving without leaving shaky foundations behind.
                    </MudText>
                    <div class="track-list">
                        <div>
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"></MudIcon>
                            <span>Find and fix knowledge gaps</span>
                        </div>
                        <div>
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"></MudIcon>
                            <span>Follow a structured C# roadmap</span>
                        </div>
                        <div>
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"></MudIcon>
                            <span>Get close reviews on your code</span>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="track-card experienced-track pa-6" Elevation="5">
                    <div class="track-icon">
                        <MudIcon Icon="@Icons.Material.Filled.Engineering"></MudIcon>
                    </div>
                    <MudText Typo="Typo.h4" Class="track-title mb-3">For Developers With Experience</MudText>
                    <MudText Typo="Typo.body1" Class="track-copy mb-5">
                        We'll build a professional project end to end, covering the parts that separate hobby code from production-ready software.
                    </MudText>
                    <div class="track-list">
                        <div>
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"></MudIcon>
                            <span>Design and architecture decisions</span>
                        </div>
                        <div>
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"></MudIcon>
                            <span>Development to professional standards</span>
                        </div>
                        <div>
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"></MudIcon>
                            <span>Deployment, CI/CD, and release workflow</span>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="production-panel pa-6 mt-8" Elevation="5">
            <MudText Typo="Typo.h4" Class="mentor-section-title mb-4">
                Work Like a Junior Developer
            </MudText>
            <MudText Typo="Typo.body1" Class="production-copy mb-5">
                Beyond your own project, you'll work under my guidance on tickets in The C# Academy. That means reading an existing codebase, understanding requirements, making changes, opening work for review, and learning the rhythm of a real production app.
            </MudText>
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <div class="practice-item">
                        <MudIcon Icon="@Icons.Material.Filled.BugReport"></MudIcon>
                        <span>Investigate real issues</span>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <div class="practice-item">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree"></MudIcon>
                        <span>Work from tickets</span>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <div class="practice-item">
                        <MudIcon Icon="@Icons.Material.Filled.Code"></MudIcon>
                        <span>Ship production changes</span>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <div class="practice-item">
                        <MudIcon Icon="@Icons.Material.Filled.FactCheck"></MudIcon>
                        <span>Learn review standards</span>
                    </div>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>

    <!-- Pricing/Subscription Section -->
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-15 mb-10">
        <MudPaper Class="subscription-section pa-10" Elevation="6">
            <MudText Typo="Typo.h4" Class="mb-2 text-center fw-bold">Ready to Start Your Journey?</MudText>
            <MudText Typo="Typo.body1" Class="mb-8 text-center" Style="color: #666;">
                Join our mentorship program and transform your learning experience
            </MudText>

            <MudGrid Spacing="3" Class="mt-4">
                <MudItem xs="12" md="4" Class="d-flex justify-center">
                    <MudPaper Class="pricing-card" Elevation="4">
                        <MudCardContent>
                            <MudText Typo="Typo.h6" Class="text-center mb-2">Starter</MudText>
                            <MudText Typo="Typo.h5" Class="text-center mud-primary-text fw-bold mb-4">1 Session/Month</MudText>
                            <MudList T="string">
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Monthly session
                                </MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Code reviews
                                </MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Email support
                                </MudListItem>
                            </MudList>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-6">
                                Get Started
                            </MudButton>
                        </MudCardContent>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4" Class="d-flex justify-center">
                    <MudPaper Class="pricing-card pricing-card-featured" Elevation="8">
                        <div class="featured-badge">Popular</div>
                        <MudCardContent>
                            <MudText Typo="Typo.h6" Class="text-center mb-2">Professional</MudText>
                            <MudText Typo="Typo.h5" Class="text-center mud-success-text fw-bold mb-4">2 Sessions/Month</MudText>
                            <MudList T="string">
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    2 monthly sessions
                                </MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Project guidance
                                </MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Priority support
                                </MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Resource library
                                </MudListItem>
                            </MudList>
                            <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Class="mt-6">
                                Get Started
                            </MudButton>
                        </MudCardContent>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4" Class="d-flex justify-center">
                    <MudPaper Class="pricing-card" Elevation="4">
                        <MudCardContent>
                            <MudText Typo="Typo.h6" Class="text-center mb-2">Elite</MudText>
                            <MudText Typo="Typo.h5" Class="text-center mud-primary-text fw-bold mb-4">Unlimited</MudText>
                            <MudList T="string">
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Unlimited sessions
                                </MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Career coaching
                                </MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Direct messaging
                                </MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Custom curriculum
                                </MudListItem>
                            </MudList>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-6">
                                Get Started
                            </MudButton>
                        </MudCardContent>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>

    <!-- CTA Section -->
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-15 mb-15">
        <MudPaper Class="cta-section pa-10 text-center" Elevation="8">
            <MudText Typo="Typo.h4" Class="mb-4 fw-bold">Have Questions?</MudText>
            <MudText Typo="Typo.body1" Class="mb-6" Style="opacity: 0.95;">
                Schedule a free consultation call to discuss your goals and see if our mentorship is right for you.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.Phone"
                       Href="https://calendly.com" Target="_blank">
                Schedule Free Consultation
            </MudButton>
        </MudPaper>
    </MudContainer>
</div>

<style>
    .mentorship-page {
        background: linear-gradient(135deg, #f6f7fb 0%, #e8edf5 100%);
        min-height: 100vh;
        padding: 20px 0;
    }

    .mentorship-hero {
        background: linear-gradient(135deg, #1c236d 0%, #2d356f 68%, #832a77 100%) !important;
        color: white;
        border-radius: 12px;
        position: relative;
        overflow: hidden;
    }

    .mentorship-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 600px;
        height: 600px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
    }

    .mentorship-title {
        font-weight: 700 !important;
        font-size: 2.5rem !important;
        line-height: 1.2;
        color: white;
    }

    .mentorship-hero .mud-typography-body1 {
        font-size: 1.1rem;
        line-height: 1.6;
        color: white;
    }

    .mentorship-chip {
        width: fit-content;
    }

    .mentorship-subscribe-btn {
        font-weight: 600;
        padding: 12px 32px !important;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    }

    .mentorship-hero-visual {
        background: rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 300px;
        backdrop-filter: blur(10px);
    }

    .hero-icon-container {
