@page "/project/{ProjectId:int}/{ProjectSlug}"
@using System.Security.Claims
@using Microsoft.Extensions.Options
@using TCSA.V2026.Components.Ads
@using TCSA.V2026.Components.UI
@using TCSA.V2026.Data.Curriculum
@using TCSA.V2026.Data.Models
@using TCSA.V2026.Data.Models.Options
@using TCSA.V2026.Data.Models.Responses
@using TCSA.V2026.Helpers
@using TCSA.V2026.Helpers.Constants
@using TCSA.V2026.Models
@using TCSA.V2026.Services
@using TCSA.V2026.Services.Challenges

@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>@Project.Title</PageTitle>

<div class="project-theme">
<MudContainer MaxWidth="MaxWidth.Large" Class="project-container">
    @if (IsLoading)
    {
        <div class="loading-state">
            <MudProgressCircular Color="Color.Default" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else
    {
        <MudPaper Class="jumbotron d-flex align-center justify-center mt-3 project-hero"
                  Style=@GetBanner()>
            <h1 class="mud-typography-h3 text-white mud-typography-align-center py-4 px-4 px-md-10 project-title" id="@ContentAnchors.ArticleTitleId">@Project.Title</h1>
        </MudPaper>
            <div class="completion-strip">
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" />
                <span>This project has been completed by <strong>@CompletionCount</strong> users</span>
            </div>

        @if (IsLoggedIn && IsCompleted)
        {
            <MudAlert Class="mt-5" Severity="Severity.Success" Elevation="2">You have completed this roadmap step.</MudAlert>
        }

        <MudGrid Class="mt-4">
            <MudItem xs="12" md="9">
                <MudPaper Class="d-flex flex-column mud-width-full section-panel section-panel-soft project-content">
                    @if (Project.Introduction != null)
                    {
                        for (var paragraphIndex = 0; paragraphIndex < Project.Introduction.Count; paragraphIndex++)
                        {
                                var paragraph = Project.Introduction[paragraphIndex];
                                var capturedParagraphIndex = paragraphIndex;
                                <MudText Class="project-paragraph" UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ProjectIntroductionParagraphId(capturedParagraphIndex) })">
                                    @((MarkupString)(paragraph.Body))
                                </MudText>
                        }
                    }
                    @if (Project.Id != 86)
                    {
                        <section class="project-feature-panel project-requirements-panel">
                        <h2 class="project-section-title">@Project.LanguageHeadings.Requirements</h2>
                        @if (!string.IsNullOrEmpty(Project.RequirementsIntro))
                        {
                            <MudText Class="project-paragraph" UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ProjectRequirementsIntroId })">@((MarkupString)(Project.RequirementsIntro))</MudText>
                        }
                        @if (Project.Requirements != null)
                        {
                            <MudList ReadOnly="true" T="MarkupString" Color="Color.Default">
                                @for (var reqIndex = 0; reqIndex < Project.Requirements.Count; reqIndex++)
                                {
                                        var req = Project.Requirements[reqIndex];
                                        var capturedReqIndex = reqIndex;
                                    <MudListItem>
                                        <div class="project-list-row">
                                            <span class="project-list-dot" aria-hidden="true"></span>
                                            <MudText UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ProjectRequirementId(capturedReqIndex) })">@((MarkupString)(req))</MudText>
                                        </div>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                        @if (!string.IsNullOrEmpty(Project.RequirementsConclusion))
                        {
                            <MudText Class="project-paragraph" UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ProjectRequirementsConclusionId })">@((MarkupString)(Project.RequirementsConclusion))</MudText>
                        }
                        </section>
                    }
                    @if (Project.LearningItems != null)
                    {
                        <h2 class="project-section-title">@Project.LanguageHeadings.Learn</h2>
                        @if (!string.IsNullOrEmpty(Project.LearningIntro))
                        {
                            <MudText Class="mt-2 mb-2" UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ProjectLearningIntroId })">@((MarkupString)(Project.LearningIntro))</MudText>
                        }
                        <MudList Class="mt-2" T="MarkupString" Color="Color.Default">
                            @for (var itemIndex = 0; itemIndex < Project.LearningItems.Count; itemIndex++)
                            {
                                var item = Project.LearningItems[itemIndex];
                                var capturedItemIndex = itemIndex;
                                <MudListItem>
                                    <MudText Class="mt-2" UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ProjectLearningItemId(capturedItemIndex) })">@((MarkupString)(item))</MudText>
                                </MudListItem>
                            }
                        </MudList>
                    }
                    @if (Project.Resources != null)
                    {
                        <h2 class="project-section-title">@Project.LanguageHeadings.Resources</h2>
                        @if (!string.IsNullOrEmpty(Project.ResourcesIntro))
                        {
                            <MudText Class="mt-2 mb-2" UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ProjectResourcesIntroId })">@((MarkupString)(Project.ResourcesIntro))</MudText>
                        }
                        <MudList T="MarkupString" Color="Color.Default">
                            @for (var itemIndex = 0; itemIndex < Project.Resources.Count; itemIndex++)
                            {
                                var item = Project.Resources[itemIndex];
                                var capturedItemIndex = itemIndex;
                                <MudListItem>
                                    <div style="display: flex;">
                                        <MudIcon Icon="@Icons.Material.Filled.ArrowCircleRight" Color="Color.Primary" Class="mr-2" />
                                        <MudText UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ProjectResourceId(capturedItemIndex) })">@((MarkupString)(item))</MudText>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                        @if (!string.IsNullOrEmpty(Project.ResourcesConclusion))
                        {
                            <MudText Class="mt-2" UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ProjectResourcesConclusionId })">@((MarkupString)(Project.ResourcesConclusion))</MudText>
                        }
                    }
                    @if (Project.Tips != null)
                    {
                        <section class="project-feature-panel project-tips-panel">
                        <h2 class="project-section-title">@Project.LanguageHeadings.Tips</h2>
                        <MudList T="MarkupString" Color="Color.Default">
                            @for (var tipIndex = 0; tipIndex < Project.Tips.Count; tipIndex++)
                            {
                                var tip = Project.Tips[tipIndex];
                                var capturedTipIndex = tipIndex;
                                <MudListItem>
                                    <div class="project-list-row">
                                        <span class="project-list-dot" aria-hidden="true"></span>
                                        <MudText UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ProjectTipId(capturedTipIndex) })">@((MarkupString)(tip))</MudText>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                        </section>
                    }

                    @if (Project.Challenges != null)
                    {
                        <section class="project-feature-panel project-challenges-panel">
                        <h2 class="project-section-title">@Project.LanguageHeadings.Challenges</h2>
                        <MudList T="MarkupString" Color="Color.Default">
                            @for (var challengeIndex = 0; challengeIndex < Project.Challenges.Count; challengeIndex++)
                            {
                                var challenge = Project.Challenges[challengeIndex];
                                var capturedChallengeIndex = challengeIndex;
                                <MudListItem>
                                    <div class="project-list-row">
                                        <span class="project-list-dot" aria-hidden="true"></span>
                                        <MudText UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ProjectChallengeId(capturedChallengeIndex) })">@((MarkupString)(challenge))</MudText>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                        </section>
                    }
                    @if (Project.Blocks != null)
                    {
                        @for (var blockIndex = 0; blockIndex < Project.Blocks.Count; blockIndex++)
                        {
                            var block = Project.Blocks[blockIndex];
                            var capturedBlockIndex = blockIndex;
                            @if (!string.IsNullOrWhiteSpace(block.Title))
                            {
                                <h2 class="project-section-title" id="@ContentAnchors.ArticleBlockTitleId(capturedBlockIndex)">@block.Title</h2>
                            }

                            @for (var paragraphIndex = 0; paragraphIndex < block.Paragraphs.Count; paragraphIndex++)
                            {
                                var paragraph = block.Paragraphs[paragraphIndex];
                                var capturedParagraphIndex = paragraphIndex;
                                if (paragraph.IsPicture)
                                {
                                    <MudPaper Class="d-flex justify-center project-media-wrap" Elevation="0">
                                        <MudImage Src="@GetImage(paragraph)" Alt="Image paragraph" Fluid="true" Class="rounded-lg" />
                                    </MudPaper>
                                }

                                else if (paragraph.IsVideo)
                                {
                                    <div class="video-wrapper project-video-wrap">
                                        <iframe class="video-iframe" src="@paragraph.VideoUrl" allowfullscreen></iframe>
                                    </div>
                                }

                                else if (paragraph.IsCode)
                                {
                                    <pre class="line-numbers project-code-block"><code class="language-csharp">@((MarkupString)paragraph.Body)</code></pre>
                                }

                                else if (!string.IsNullOrEmpty(paragraph.Body))
                                {
                                    if (!string.IsNullOrWhiteSpace(paragraph.BackgroundColor))
                                    {
                                        var bgStyle = $"background-color: {paragraph.BackgroundColor}; padding: 1rem;";
                                        var textStyle = $"color: {paragraph.FontColor};";
                                        <MudText Class="project-paragraph" Style="@textStyle" Typo="Typo.body1" UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ArticleBlockParagraphId(capturedBlockIndex, capturedParagraphIndex) })">
                                            @((MarkupString)paragraph.Body)
                                        </MudText>
                                    }
                                    else
                                    {
                                        <MudText Class="project-paragraph" Typo="Typo.body1" UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ArticleBlockParagraphId(capturedBlockIndex, capturedParagraphIndex) })">
                                            @((MarkupString)paragraph.Body)
                                        </MudText>
                                    }
                                }
                            }
                        }
                    }

                    @if (Project.Screenshots != null)
                    {
                        <h2 class="project-section-title">Example Screenshots</h2>
                        @if (Project.Screenshots.Count == 1)
                        {
                            <MudPaper Class="d-flex justify-center mx-20 project-media-wrap" Elevation="0">
                                <MudImage Src="@($"img/{Project.Screenshots[0]}")" Fluid="true" Class="rounded-lg" />
                            </MudPaper>
                        }
                        else if (Project.Screenshots.Count > 1)
                        {
                            <MudCarousel Style="height: 350px;" ShowArrows EnableSwipeGesture ItemsSource="Project.Screenshots" AutoCycle="false">
                                <ItemTemplate>
                                    <div class="d-flex justify-center" style="height: 100%;">
                                        <MudImage Src="@($"img/{context}")"
                                                  Class="rounded-lg"
                                                  Style="max-height: 300px; max-width: 100%;" />
                                    </div>
                                </ItemTemplate>
                            </MudCarousel>
                        }
                    }

                    @if (!string.IsNullOrEmpty(Project.RepositoryLink))
                    {
                        <MudStack Class="pb-5 mt-10 align-start align-md-center repository-panel" Row Breakpoint="Breakpoint.SmAndDown" Spacing="6">
                            <MudImage Src="img/github.png" Width="70" Alt="GitHub logo" />
                            <div>
                                <h2 class="mud-typography-h5 mb-2">@Project.LanguageHeadings.ReviewRepository</h2>

                                <MudLink Href="@Project.RepositoryLink" Target="_blank" Style="word-break: break-word;">
                                    @Project.RepositoryLink
                                </MudLink>
                            </div>
                        </MudStack>
                    }

                    @if (IsLoggedIn && Project.Area == Area.SQL && !IsCompleted)
                    {
                        @if (CodeWarsNotFoundShowing)
                        {
                            <h2 class="project-section-title">You haven't integrated Codewars yet.</h2>
                            <MudText Class="mt-10 mb-2" Typo="Typo.body1">
                                In The C# Academy's Dashboard, you'll see a button where you can insert your Codewars user name. Your input has to match Code War's username exactly, including case sensitivity, or we won't be able to track your results.

                                Once you have completed a challenge, refresh this page and you'll be able to see your progress so far at the bottom of the page. Once all challenges are finished, the project will be marked as completed automatically.
                            </MudText>
                        }
                        else
                        {
                            <h2 class="project-section-title">Your Progress</h2>
                            <MudList T="MarkupString" Color="Color.Default">
                                @foreach (var challenge in Project.CodeWarsChallenges)
                                {
                                    <MudListItem>
                                        <div style="display: flex;">
                                            @if (challenge.IsCompleted)
                                            {
                                                <MudIcon Icon="@Icons.Material.Outlined.CheckBox" Size="Size.Medium" Color="Color.Success" Class="mr-2" />
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@Icons.Material.Outlined.CheckBoxOutlineBlank" Size="Size.Medium" Color="Color.Warning" Class="mr-2" />
                                            }
                                            <MudText>@((MarkupString)(challenge.Name))</MudText>
                                        </div>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    }

                    @if (IsLoggedIn && !IsCompleted && IsAdmin) 
                    {
                        @if (AccountabilityBuddyInfo == null)
                        {
                            <MudButton Class="mt-2 ml-5 mr-5"
                                       Size="@Size.Medium"
                                       Variant="@Variant.Filled"
                                       OnClick="@(() => OpenAccountabilityDialog())"
                                       Color="Color.Primary"
                                       StartIcon="fas fa-eye">
                                Set Up Accountability Buddy
                            </MudButton>
                        }
                        else
                        {
                            <MudHidden Breakpoint="Breakpoint.MdAndDown">
                                <MudCard Class="mt-1 accountability-card">
                                    <MudCardHeader Class="d-flex align-items-center">
                                        <CardHeaderAvatar>
                                            <MudImage Width="40" Src="@($"img/icons/icons8-coach-64.png")" />
                                        </CardHeaderAvatar>
                                        <CardHeaderContent>
                                            <h3 class="mud-typography-body1 mud-primary-text" style="font-weight: bold;">You set up the accountability buddy for this project</h3>
                                            <MudText Typo="Typo.body2">Your deadline is: @AccountabilityBuddyInfo.DeadLineUtc</MudText>
                                        </CardHeaderContent>
                                    </MudCardHeader>
                                </MudCard>
                            </MudHidden>
                        }
                    }

                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="3">
                <aside class="project-ad-rail" aria-label="Advertisement">
                    <div class="project-sidebar-ad">
                        <AdSenseAd Slot="5997983008" />
                    </div>
                    <div class="project-sidebar-ad">
                        <AdSenseAd Slot="5606980623" />
                    </div>
                </aside>
            </MudItem>
        </MudGrid>
    }
</MudContainer>
</div>

    @code {
    [Inject] private AuthenticationStateProvider AuthenticationState { get; set; }
    [Inject] private IProjectService ProjectService { get; set; }
    [Inject] private IAccountabilityBuddyService AccountabilityBuddyService { get; set; }
    [Inject] private ICodewarsService CodewarsService { get; set; }

    [Inject] private IDialogService DialogService { get; set; }
    [Inject] private IJSRuntime JS { get; set; }
    [Inject] private NavigationManager NavigationManager { get; set; }

    [Inject] private IOptions<FeatureToggleOptions> FeatureToggles { get; set; }


    [Parameter] public string ProjectSlug { get; set; }
    [Parameter] public int ProjectId { get; set; }

    private Project Project { get; set; }

    private bool IsLoggedIn = false;
    private bool IsCompleted = false;
    private bool IsLoading = false;
    private bool IsPendingReview = false;
    private ProjectStatus Status { get; set; } = ProjectStatus.None;
    private UserAccountabilityProject AccountabilityBuddyInfo = null;

    private string UserId = string.Empty;
    private string UserEmail = string.Empty;
    private bool CodeWarsNotFoundShowing = false;
    private bool IsAdmin = false;
    private int CompletionCount = 0;

    protected async override Task OnInitializedAsync()
    {
        await OnParametersSetAsync();
        CompletionCount = await ProjectService.GetCompletionCount(ProjectId, false);

    }

    private async Task OpenAccountabilityDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };

        var parameters = new DialogParameters<TCSAAccountabilityBuddyDialog>
        {
            { p => p.ProjectId, ProjectId },
            { p => p.Email, UserEmail },
            { p => p.UserId, UserId }
        };

        var dialog = await DialogService.ShowAsync<TCSAAccountabilityBuddyDialog>("Accountability Buddy", parameters, options);
        var result = await dialog.Result;

        if (result.Canceled)
            return;

        if (result.Data is string checkoutUrl && !string.IsNullOrWhiteSpace(checkoutUrl))
        {
            // forceLoad is important for external navigation
            NavigationManager.NavigateTo(checkoutUrl, forceLoad: true);
            return;
        }

        if (result.Data is bool noCheckoutNeeded && noCheckoutNeeded)
        {
            var accountabilityResponse = await AccountabilityBuddyService.GetUserAccountability(UserId, ProjectId);
            if (accountabilityResponse.IsSuccessful)
            {
                AccountabilityBuddyInfo = accountabilityResponse.Data;
            }
        }
    }

    private string GetBanner()
    {
        var banner = string.IsNullOrEmpty(Project.BannerUrl) ? "article-banner.jpg" : Project.BannerUrl;
        return $"min-height: 350px; background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('/img/banners/{banner}'); background-size: cover; background-position: center;";
    }

    private async Task CheckCodeWars()
    {
        try
        {
            IsCompleted = await ProjectService.IsProjectCompleted(UserId, ProjectId);

            var challengesResult = await CodewarsService.GetCodeWarsCompletedChallenges(UserId, Project.CodeWarsChallenges);

            Project.CodeWarsChallenges = challengesResult.Challenges;

            if (challengesResult.Status == ResponseStatus.Fail)
            {
                CodeWarsNotFoundShowing = true;
            }

            if (challengesResult.Status == ResponseStatus.Success
                && !IsCompleted
                && !Project.CodeWarsChallenges.Any(x => x.IsCompleted == false))
            {
                await CodewarsService.MarkSqlProjectAsCompleted(Project.Id, UserId);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    private string GetImage(Paragraph paragraph) => $"img/{paragraph.PictureUrl}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("highlightCode");
        }

        var AuthSate = await AuthenticationState.GetAuthenticationStateAsync();
    }

    protected async override Task OnParametersSetAsync()
    {
        Project = ProjectHelper.GetProjects().Single(x => x.Id == ProjectId);

        var AuthSate = await AuthenticationState.GetAuthenticationStateAsync();

        if (AuthSate.User.Identity.IsAuthenticated)
        {
            IsLoggedIn = true;
            var claims = AuthSate.User;
            UserId = claims.FindFirstValue(ClaimTypes.NameIdentifier);
            UserEmail = claims.FindFirstValue(ClaimTypes.Email);
            IsAdmin = claims.IsInRole("Admin");

            IsCompleted = await ProjectService.IsProjectCompleted(UserId, ProjectId);
            var accountabilityResponse = await AccountabilityBuddyService.GetUserAccountability(UserId, ProjectId);
            if (accountabilityResponse.IsSuccessful)
            {
                AccountabilityBuddyInfo = accountabilityResponse.Data;
            };
        }

        if (!IsCompleted && Project.Area == Area.SQL)
        {
            await CheckCodeWars();
        }

        IsLoading = false;
    }
}

<style>
    .project-theme {
        position: relative;
        isolation: isolate;
        padding-bottom: 2rem;
        overflow-x: hidden;
    }

        .project-theme::before,
        .project-theme::after {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            z-index: -1;
            filter: blur(80px);
            opacity: 0.16;
            pointer-events: none;
        }

        .project-theme::before {
            top: 160px;
            right: -170px;
            background: rgba(var(--mud-palette-primary-rgb), 0.62);
        }

        .project-theme::after {
            top: 980px;
            left: -180px;
            background: rgba(var(--mud-palette-secondary-rgb), 0.52);
        }

    .project-container {
        position: relative;
    }

    .loading-state {
        min-height: 40vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .project-hero {
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.24);
        box-shadow: 0 18px 38px rgba(0,0,0,0.2) !important;
    }

    .project-title {
        line-height: 1.2;
        font-weight: 800;
        text-shadow: 0 6px 20px rgba(0,0,0,0.35);
    }

    .section-panel {
        padding: 0.8rem 0.5rem;
        border-radius: 22px;
    }

    .section-panel-soft {
        border: 1px solid rgba(var(--mud-palette-lines-default-rgb), 0.55);
        background: linear-gradient(180deg, rgba(var(--mud-palette-surface-rgb), 0.95) 0%, rgba(var(--mud-palette-secondary-rgb), 0.05) 100%);
        box-shadow: 0 14px 34px rgba(0,0,0,0.08);
    }

    .project-content {
        margin-top: 0.25rem;
        padding: 1.25rem 2.5rem 2.75rem;
    }

    .project-section-title {
        color: #C9436E;
        font-size: 1.4rem;
        font-weight: 800;
        line-height: 1.3;
        margin: 1.5rem 0 0.85rem;
        padding-left: 0.9rem;
        border-left: 4px solid #C9436E;
    }

    .mud-theme-dark .project-section-title,
    .mud-application.mud-theme-dark .project-section-title {
        color: var(--mud-palette-text-primary);
        border-left-color: var(--mud-palette-primary);
    }

    .project-paragraph {
        color: var(--mud-palette-text-primary);
        line-height: 1.8;
        margin: 0.35rem 0 0.9rem;
    }

    .project-feature-panel {
        --panel-accent: var(--mud-palette-primary);
        margin: 1.75rem 0;
        padding: 1.25rem 1.4rem 1rem;
        border: 1px solid color-mix(in srgb, var(--panel-accent) 28%, var(--mud-palette-lines-default));
        border-left: 6px solid var(--panel-accent);
        border-radius: 14px;
        background: linear-gradient(135deg, color-mix(in srgb, var(--panel-accent) 13%, var(--mud-palette-surface)) 0%, var(--mud-palette-surface) 74%);
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
    }

    .project-requirements-panel {
        --panel-accent: #3f8f65;
    }

    .project-tips-panel {
        --panel-accent: #d49a13;
    }

    .project-challenges-panel {
        --panel-accent: #c84d4d;
    }

    .project-feature-panel .project-section-title {
        color: color-mix(in srgb, var(--panel-accent) 82%, var(--mud-palette-text-primary));
        margin-top: 0;
        border-left-color: var(--panel-accent);
    }

    .project-feature-panel .mud-list {
        padding: 0;
        background: transparent;
    }

    .project-list-row {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        width: 100%;
    }

    .project-list-dot {
        width: 11px;
        height: 11px;
        margin-top: 0.38rem;
        border-radius: 50%;
        background: var(--panel-accent);
        box-shadow: 0 0 0 4px color-mix(in srgb, var(--panel-accent) 18%, transparent);
        flex: 0 0 auto;
    }

    .project-ad-rail {
        display: flex;
        flex-direction: column;
        gap: 10rem;
        padding: 2rem 0;
    }

    .project-sidebar-ad {
        width: 100%;
        min-width: 0;
        min-height: 600px;
    }

    .project-media-wrap {
        margin: 2rem 0;
        padding: 1.5rem;
        border-radius: 16px;
        background: var(--mud-palette-background-grey) !important;
        border: 1px solid var(--mud-palette-lines-default);
        overflow: hidden;
    }

    .project-video-wrap {
        margin: 2rem 0;
    }

    .project-code-block {
        margin: 1.75rem 0 !important;
        padding: 1.25rem !important;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        overflow: auto;
    }

    .repository-panel {
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.18);
        border-radius: 14px;
        padding: 1rem;
        background: linear-gradient(160deg, rgba(var(--mud-palette-surface-rgb), 1) 0%, rgba(var(--mud-palette-primary-rgb), 0.05) 100%);
