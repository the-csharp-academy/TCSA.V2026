@page "/article/{ArticleId:int}/{ArticleSlug}"
@using System.Security.Claims
@using TCSA.V2026.Components.Ads
@using TCSA.V2026.Data.Curriculum
@using TCSA.V2026.Data.Models
@using TCSA.V2026.Helpers.Constants
@using TCSA.V2026.Services

@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>@Article.Title</PageTitle>

<div class="article-theme">
<MudContainer MaxWidth="MaxWidth.Large" Class="article-container">
    <MudPaper Class="jumbotron d-flex align-center justify-center mt-3 article-hero" Style=@GetBanner()>
            <h1 class="mud-typography-h3 text-white mud-typography-align-center py-4 px-4 px-md-10 article-title" id="@ContentAnchors.ArticleTitleId">@Article.Title</h1>
    </MudPaper>
        <div class="completion-strip">
            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" />
            <span>This article has been read by <strong>@CompletionCount</strong> users</span>
        </div>
    @if (IsLoading)
    {
        <div class="loading-state">
            <MudProgressCircular Color="Color.Default" Indeterminate="true" Size="Size.Large" />
        </div>
    }

    @if (IsLoggedIn && IsCompleted)
    {
        <MudAlert Class="mt-5" Severity="Severity.Success" Elevation="2">You have completed this roadmap step.</MudAlert>
    }

    <MudGrid Class="mt-4">
        <MudItem xs="12">
            <MudPaper Class="d-flex flex-column mud-width-full py-1 pb-10 px-4 px-md-10 section-panel section-panel-soft article-content">
                @for (var blockIndex = 0; blockIndex < Article.Blocks.Count; blockIndex++)
                {
                    var block = Article.Blocks[blockIndex];
                    var capturedBlockIndex = blockIndex;
                    <div class="@GetBlockClass(block)" style="@GetBlockStyle(block)">
                        @if (!string.IsNullOrWhiteSpace(block.Title))
                        {
                            <h2 class="mud-typography-h6 mt-10 mb-2" id="@ContentAnchors.ArticleBlockTitleId(capturedBlockIndex)">@block.Title</h2>
                        }

                        @for (var paragraphIndex = 0; paragraphIndex < block.Paragraphs.Count; paragraphIndex++)
                        {
                            var paragraph = block.Paragraphs[paragraphIndex];
                            var capturedParagraphIndex = paragraphIndex;
                            if (paragraph.IsPicture)
                            {
                                <MudPaper Class="d-flex justify-center mx-20 mt-10 article-media-wrap" Elevation="0">
                                    <MudImage Src="@GetImage(paragraph)" Alt="Image paragraph" Fluid="true" Class="rounded-lg" />
                                </MudPaper>
                            }

                            else if (paragraph.IsVideo)
                            {
                                <div class="video-wrapper mt-3 mb-4">
                                    <iframe class="video-iframe" src="@paragraph.VideoUrl" allowfullscreen></iframe>
                                </div>
                            }

                            else if (paragraph.IsCode)
                            {
                                <pre class="line-numbers"><code class="language-csharp">@((MarkupString)paragraph.Body)</code></pre>
                            }

                            else if (!string.IsNullOrEmpty(paragraph.Body))
                            {
                                if (!string.IsNullOrWhiteSpace(paragraph.BackgroundColor))
                                {
                                    var bgStyle = $"background-color: {paragraph.BackgroundColor}; padding: 1rem;";
                                    var textStyle = $"color: {paragraph.FontColor};";

                                    <MudPaper Style="@bgStyle" Elevation="1" Class="my-2">
                                            <MudText Style="@textStyle" Typo="Typo.body1"
                                                UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ArticleBlockParagraphId(capturedBlockIndex, capturedParagraphIndex) })">
                                            @((MarkupString)paragraph.Body)
                                        </MudText>
                                    </MudPaper>
                                }
                                else
                                {
                                    <MudText Class="mt-2 mb-5" Typo="Typo.body1"
                                             UserAttributes="@(new Dictionary<string, object> { ["id"] = ContentAnchors.ArticleBlockParagraphId(capturedBlockIndex, capturedParagraphIndex) })">
                                        @((MarkupString)paragraph.Body)
                                    </MudText>
                                }
                            }
                        }
                    </div>
                }
            </MudPaper>
        </MudItem>
@*         <MudItem xs="12" md="2">
            <MudPaper Class="d-flex align-center justify-center mud-width-full py-8 mt-4">
                <div style="width:250px; min-height:250px;">
                    <CourseSidebarAd />
                </div>
            </MudPaper>
        </MudItem> *@
    </MudGrid>

    @if (IsLoggedIn && !IsCompleted)
    {
        <div class="d-flex justify-center my-5 article-action-wrap">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="MarkAsRead"
                       Disabled="IsSubmitting"
                       Loading="IsSubmitting">
                Mark as Read
            </MudButton>
        </div>
    }

</MudContainer>
</div>

@code {
    [Inject] private AuthenticationStateProvider AuthenticationState { get; set; }
    [Inject] private IProjectService ProjectService { get; set; }
    [Inject] private IJSRuntime JS { get; set; }
    [Inject] private ISnackbar SnackbarService { get; set; }

    [Parameter] public string ArticleSlug { get; set; }
    [Parameter] public int ArticleId { get; set; }

    private Article Article { get; set; }

    private bool IsLoggedIn = false;
    private bool HasNext = false;
    private bool IsCompleted = false;
    private bool IsLoading = true;
    private bool IsSubmitting = false;
    private string UserId = string.Empty;
    private string BackgroundImage;
    private int CompletionCount = 0;

    protected async override Task OnInitializedAsync()
    {
        await OnParametersSetAsync();
        CompletionCount = await ProjectService.GetCompletionCount(ArticleId, true);
    }

    private string GetBanner()
    {
        var banner = string.IsNullOrEmpty(Article.BannerUrl) ? "article-banner.jpg" : Article.BannerUrl;
        return $"min-height: 250px; background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('/img/banners/{banner}'); background-size: cover; background-position: center;";
    }

    private string GetImage(Paragraph paragraph) => $"img/{paragraph.PictureUrl}";

    private static string GetBlockClass(Data.Models.Block block)
    {
        return string.IsNullOrWhiteSpace(block.CssClass)
            ? "article-content-block"
            : $"article-content-block {block.CssClass}";
    }

    private static string? GetBlockStyle(Data.Models.Block block)
    {
        if (string.IsNullOrWhiteSpace(block.BackgroundColor) && string.IsNullOrWhiteSpace(block.FontColor))
        {
            return null;
        }

        var styles = new List<string>();

        if (!string.IsNullOrWhiteSpace(block.BackgroundColor))
        {
            styles.Add($"background-color: {block.BackgroundColor}");
        }

        if (!string.IsNullOrWhiteSpace(block.FontColor))
        {
            styles.Add($"color: {block.FontColor}");
        }

        return string.Join("; ", styles);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("highlightCode");
        }

        var AuthSate = await AuthenticationState.GetAuthenticationStateAsync();
    }

    protected async override Task OnParametersSetAsync()
    {
        Article = ArticleHelper.GetArticles().Single(x => x.Id == ArticleId);

        var AuthSate = await AuthenticationState.GetAuthenticationStateAsync();

        if (AuthSate.User.Identity.IsAuthenticated)
        {
            IsLoggedIn = true;
            var claims = AuthSate.User;
            UserId = claims.FindFirstValue(ClaimTypes.NameIdentifier);

            IsCompleted = await ProjectService.IsProjectCompleted(UserId, ArticleId);
        }

        IsLoading = false;
    }

    private async Task MarkAsRead()
    {
        IsSubmitting = true;

        var response = await ProjectService.PostArticle(ArticleId, UserId, string.Empty, true, false);

        IsSubmitting = false;

        if (response.Status == Data.Models.Responses.ResponseStatus.Success)
        {
            SnackbarService.Add("Article successfully marked as read", Severity.Success);
        }
        else
        {
            SnackbarService.Add("There was an error", Severity.Error);
        }

        IsCompleted = await ProjectService.IsProjectCompleted(UserId, ArticleId);
    }
}

<style>
    .article-theme {
        position: relative;
        isolation: isolate;
        padding-bottom: 2rem;
        overflow-x: hidden;
    }

        .article-theme::before,
        .article-theme::after {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            z-index: -1;
            filter: blur(80px);
            opacity: 0.16;
            pointer-events: none;
        }

        .article-theme::before {
            top: 160px;
            right: -170px;
            background: rgba(var(--mud-palette-primary-rgb), 0.62);
        }

        .article-theme::after {
            top: 980px;
            left: -180px;
            background: rgba(var(--mud-palette-secondary-rgb), 0.52);
        }

    .article-container {
        position: relative;
    }

    .loading-state {
        min-height: 24vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .article-hero {
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.24);
        box-shadow: 0 18px 38px rgba(0,0,0,0.2) !important;
    }

    .article-title {
        line-height: 1.2;
        text-shadow: 0 6px 20px rgba(0,0,0,0.35);
    }

    .section-panel {
        padding: 0.8rem 0.5rem;
        border-radius: 22px;
    }

    .section-panel-soft {
        border: 1px solid rgba(var(--mud-palette-lines-default-rgb), 0.55);
        background: linear-gradient(180deg, rgba(var(--mud-palette-surface-rgb), 0.95) 0%, rgba(var(--mud-palette-secondary-rgb), 0.05) 100%);
        box-shadow: 0 14px 34px rgba(0,0,0,0.08);
    }

    .article-content {
        margin-top: 0.4rem;
    }

    .article-content-block {
        border-radius: 14px;
        margin: 1.25rem 0;
    }

    .article-content-block[style*="background-color"] {
        padding: 1.25rem 1.4rem;
    }

    .course-exercise-block {
        padding: 1.4rem 1.5rem 0.5rem;
        border: 1px solid color-mix(in srgb, var(--mud-palette-success) 28%, var(--mud-palette-lines-default));
        border-left: 6px solid color-mix(in srgb, var(--mud-palette-success) 76%, #2f6f62);
        background: linear-gradient(135deg, color-mix(in srgb, var(--mud-palette-success) 13%, var(--mud-palette-surface)) 0%, var(--mud-palette-surface) 72%);
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
    }

    .course-exercise-block h2 {
        margin-top: 0 !important;
        color: color-mix(in srgb, var(--mud-palette-success) 72%, var(--mud-palette-text-primary));
    }

    .article-media-wrap {
        border-radius: 16px;
    }

    .article-action-wrap {
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.18);
        border-radius: 14px;
        padding: 1rem;
        background: linear-gradient(160deg, rgba(var(--mud-palette-surface-rgb), 1) 0%, rgba(var(--mud-palette-primary-rgb), 0.05) 100%);
    }

    .article-theme a {
        color: #1976d2; /* Material blue */
    }

    .completion-strip {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(var(--mud-palette-primary-rgb), 0.08);
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.18);
        border-radius: 10px;
        padding: 0.5rem 1.2rem;
        margin-top: 1rem;
        font-size: 0.9rem;
    }

    @@media (max-width: 960px) {
        .article-hero {
            border-radius: 20px;
        }

        .section-panel {
            border-radius: 18px;
            padding: 0.6rem 0.35rem;
        }

        .article-theme::before,
        .article-theme::after {
            width: 320px;
            height: 320px;
            filter: blur(65px);
        }
    }
</style>

