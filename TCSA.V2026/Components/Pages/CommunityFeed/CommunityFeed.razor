@using TCSA.V2026.Components.UI
@using TCSA.V2026.Data.DTOs
@using TCSA.V2026.Data.Models
@using TCSA.V2026.Data.Models.Responses
@using TCSA.V2026.Helpers
@using TCSA.V2026.Helpers.Constants
@using TCSA.V2026.Services
@page "/feed"

<PageTitle>Community Feed</PageTitle>

<MudContainer>
    <h1 class="mud-primary-text mt-3">Community Feed</h1>
    <p class="mb-4 text-secondary mud-typography-body1">See the latest achievements and project completions across the platform.</p>
    <MudGrid Spacing="2">
        @if (_items.Count != 0)
        {
            @foreach (var item in _items)
            {
                <MudItem Class="d-flex" xs="12" sm="6" lg="4">
                    <MudPaper Class="pa-4 mb-3 d-flex" Elevation="2" Width="100%">
                        <div class="d-flex align-center gap-2">
                            <FeedItemDisplay Item="item" IconSize="3em" />
                        </div>
                    </MudPaper>
                </MudItem>
            }
        }
        else if (!_isLoading)
        {
            <MudItem xs="12">
                <div class="text-center my-4">
                    <span>No feed items found.</span>
                </div>
            </MudItem>
        }
    </MudGrid>
    @if (_nextCursor is not null)
    {
        <div class="d-flex justify-center mt-4 mb-6">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="_isLoading"
                       OnClick="LoadMoreAsync">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Load More
            </MudButton>
        </div>
    }
</MudContainer>

@code {
    [Inject] private IFeedService FeedService { get; set; } = default!;

    private List<FeedDisplay> _items = [];
    private string? _nextCursor;
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;

        var page = await FeedService.GetFeedItemsByCursor(null);
        _items = page.Items;
        _nextCursor = page.NextCursor;

        _isLoading = false;
    }

    private async Task LoadMoreAsync()
    {
        _isLoading = true;

        var page = await FeedService.GetFeedItemsByCursor(_nextCursor);
        _items.AddRange(page.Items);
        _nextCursor = page.NextCursor;

        _isLoading = false;
    }
}
