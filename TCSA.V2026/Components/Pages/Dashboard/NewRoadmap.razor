@page "/newroadmap"
@using MudBlazor

<h3>Roadmap</h3>
<div class="roadmap-container">
    @foreach (var node in Nodes)
    {
        <div class="roadmap-node-wrapper">
            <MudCard Class="roadmap-node" Style="cursor:pointer;" @onclick="() => OpenNodeDialog(Nodes.IndexOf(node))">
                <MudCardContent>
                    <MudIcon Icon="@node.Icon" Size="Size.Large" Color="Color.Primary" />
                </MudCardContent>
                <MudCardActions>
                    <MudText Typo="Typo.subtitle2">@node.Title</MudText>
                </MudCardActions>
            </MudCard>
            @if (Nodes.IndexOf(node) < Nodes.Count - 1)
            {
                <div class="roadmap-connector"></div>
            }
        </div>
    }
</div>

@if (DialogOpen && SelectedNode != null)
{
    <div class="modal-overlay" @onclick="CloseDialog">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <MudText Typo="Typo.h5">@SelectedNode.Title</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseDialog" />
            </div>
            <div class="modal-body">
                <MudText>@SelectedNode.Content</MudText>
            </div>
            <div class="modal-footer">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CloseDialog">Close</MudButton>
            </div>
        </div>
    </div>
}

<style>
.roadmap-container {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin: 40px 0;
    flex-wrap: wrap;
}

.roadmap-node-wrapper {
    display: flex;
    align-items: center;
}

.roadmap-node {
    min-width: 100px;
    min-height: 100px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    margin: 0 8px;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
}

.roadmap-node:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    transform: translateY(-2px);
}

.roadmap-connector {
    width: 60px;
    height: 2px;
    border-bottom: 2px dotted #1976d2;
    margin: 0 8px;
}

.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}

.modal-content {
    background: white;
    border-radius: 8px;
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.2);
    max-width: 500px;
    width: 90%;
    z-index: 1001;
}

.modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px;
    border-bottom: 1px solid #e0e0e0;
}

.modal-body {
    padding: 24px;
    max-height: 400px;
    overflow-y: auto;
}

.modal-footer {
    display: flex;
    justify-content: flex-end;
    padding: 16px 24px;
    border-top: 1px solid #e0e0e0;
    gap: 8px;
}
</style>

@code {
    public class RoadmapNode
    {
        public string Title { get; set; }
        public string Icon { get; set; }
        public string Content { get; set; }
    }

    List<RoadmapNode> Nodes = new()
    {
        new RoadmapNode { Title = "Start", Icon = Icons.Material.Filled.Flag, Content = "This is the starting point of your roadmap." },
        new RoadmapNode { Title = "Learn", Icon = Icons.Material.Filled.School, Content = "Here you learn the basics." },
        new RoadmapNode { Title = "Build", Icon = Icons.Material.Filled.Build, Content = "Now you build your first project!" }
    };

    bool DialogOpen = false;
    RoadmapNode? SelectedNode;

    void OpenNodeDialog(int index)
    {
        SelectedNode = Nodes[index];
        DialogOpen = true;
    }

    void CloseDialog()
    {
        DialogOpen = false;
        SelectedNode = null;
    }
}
