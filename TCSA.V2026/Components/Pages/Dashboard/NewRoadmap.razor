<style>
    .roadmap-grid {
        display: grid;
        margin: 40px 0;
    }

    .roadmap-cell {
        position: relative;
        width: 140px;
        height: 140px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .roadmap-node {
        width: 100px;
        height: 100px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: box-shadow 0.3s ease, transform 0.3s ease;
        z-index: 2;
        background: white;
        position: relative;
    }

    .roadmap-node-content {
        padding: 8px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .roadmap-node-image {
        width: 56px;
        height: 56px;
        object-fit: contain;
    }

    .roadmap-node-actions {
        justify-content: center;
        padding-top: 0;
    }

        .roadmap-node:hover {
            box-shadow: 0 4px 16px rgba(0,0,0,0.15);
            transform: translateY(-2px);
        }

    .connector {
        position: absolute;
        z-index: 1;
        pointer-events: none;
    }

    .connector-right {
        left: 50%;
        top: 50%;
        width: 50%;
        border-top: 2px solid #1976d2;
    }

    .connector-left {
        right: 50%;
        top: 50%;
        width: 50%;
        border-top: 2px solid #1976d2;
    }

    .connector-bottom {
        top: 50%;
        left: 50%;
        height: 50%;
        border-left: 2px solid #1976d2;
    }

    .connector-top {
        bottom: 50%;
        left: 50%;
        height: 50%;
        border-left: 2px solid #1976d2;
    }
</style>