@page "/dashboard/Courses"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using TCSA.V2026.Components.UI
@using TCSA.V2026.Data.Curriculum
@using TCSA.V2026.Data.DTOs
@using TCSA.V2026.Data.Models
@using TCSA.V2026.Services

<PageTitle>Courses</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="courses-page">
    <h1 class="visually-hidden">Courses</h1>
    @if (User is not null)
    {
        <DashboardToolBar User="@User"></DashboardToolBar>
    }

    @if (IsLoading)
    {
        <div class="courses-loading">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else
    {
        <section class="@(IsLoggedIn ? "courses-hero" : "courses-hero courses-hero-public")">
            <div>
                <MudText Typo="Typo.overline" Class="courses-eyebrow">Learning Path</MudText>
                <MudText Typo="Typo.h3" Class="courses-heading">Courses</MudText>
                <MudText Typo="Typo.body1" Class="courses-copy">
                    Explore focused C# Academy courses and learn chapter by chapter at your own pace.
                </MudText>
            </div>
            @if (IsLoggedIn)
            {
                <div class="courses-summary">
                    <div>
                        <span class="summary-value">@CompletedChapters</span>
                        <span class="summary-label">chapters completed</span>
                    </div>
                    <div>
                        <span class="summary-value">@CoursesInProgress</span>
                        <span class="summary-label">in progress</span>
                    </div>
                    <div>
                        <span class="summary-value">@CompletedCourses</span>
                        <span class="summary-label">courses finished</span>
                    </div>
                </div>
            }
        </section>

        @if (IsLoggedIn)
        {
            <div class="overall-progress">
                <div>
                    <MudText Typo="Typo.subtitle2">Overall progress</MudText>
                    <MudText Typo="Typo.caption">@CompletedChapters of @TotalChapters chapters completed</MudText>
                </div>
                <MudProgressLinear Value="@OverallProgress" Color="Color.Primary" Rounded="true" Class="overall-progress-bar" />
            </div>
        }

        <MudGrid Spacing="3" Class="courses-grid">
            @foreach (var course in DashboardCourses)
            {
                <MudItem xs="12" sm="6" lg="4">
                    <article class="@GetCourseCardClass(course.Status)">
                        <div class="course-card-header">
                            <div class="course-icon-shell">
                                <MudImage Width="38" Height="38" Src="@($"img/icons/{course.ImgUrl}")" Alt="@course.Title" />
                            </div>
                            <div class="course-card-chips">
                                <MudChip T="string"
                                         Size="Size.Small"
                                         Variant="Variant.Filled"
                                         Color="@GetLevelColor(course.Level)">
                                    @GetLevelLabel(course.Level)
                                </MudChip>
                                @if (IsLoggedIn)
                                {
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Variant="Variant.Filled"
                                             Color="@GetStatusColor(course.Status)">
                                        @GetStatusLabel(course.Status)
                                    </MudChip>
                                }
                            </div>
                        </div>

                        <div class="course-card-body">
                            <MudText Typo="Typo.h6" Class="course-card-title">@course.Title</MudText>
                            <MudText Typo="Typo.body2" Class="course-card-description">@course.Description</MudText>
                        </div>

                        @if (IsLoggedIn)
                        {
                            <div class="course-progress-row">
                                <MudText Typo="Typo.caption">@course.CompletedChapters / @course.TotalChapters @course.ChapterLabel</MudText>
                                <MudText Typo="Typo.caption">@course.ProgressPercent%</MudText>
                            </div>
                            <MudProgressLinear Value="@course.ProgressPercent"
                                               Color="@GetStatusColor(course.Status)"
                                               Rounded="true"
                                               Class="course-progress-bar" />
                        }

                        <MudButton FullWidth="true"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick="@(() => NavigateToCourse(course.Id))"
                                   Class="course-action">
                            @(IsLoggedIn ? GetActionLabel(course.Status) : "View Course")
                        </MudButton>
                        @if (IsLoggedIn && course.CompletedChapters > 0)
                        {
                            <MudButton FullWidth="true"
                                       Variant="Variant.Text"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.RestartAlt"
                                       OnClick="@(() => ConfirmResetCourse(course.Id))"
                                       Disabled="@IsResettingCourse"
                                       Class="course-reset-action">
                                Reset course
                            </MudButton>
                        }
                    </article>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

<style>
    .courses-page {
        padding-top: 24px;
        padding-bottom: 48px;
    }

    .courses-loading {
        min-height: 360px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .courses-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(260px, 420px);
        gap: 24px;
        align-items: center;
        margin-top: 20px;
        padding: 28px;
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
        background: linear-gradient(135deg, rgba(25, 118, 210, 0.12), rgba(76, 175, 80, 0.08));
    }

    .courses-hero-public {
        grid-template-columns: minmax(0, 1fr);
    }

    .courses-eyebrow {
        color: var(--mud-palette-primary);
        font-weight: 700;
    }

    .courses-heading {
        margin-top: 4px;
        font-weight: 800;
    }

    .courses-copy {
        max-width: 680px;
        margin-top: 10px;
        color: var(--mud-palette-text-secondary);
    }

    .courses-summary {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
    }

    .courses-summary > div {
        min-height: 92px;
        padding: 16px;
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
        background: var(--mud-palette-surface);
    }

    .summary-value {
        display: block;
        font-size: 1.75rem;
        line-height: 1;
        font-weight: 800;
    }

    .summary-label {
        display: block;
        margin-top: 8px;
        color: var(--mud-palette-text-secondary);
        font-size: 0.8125rem;
    }

    .overall-progress {
        display: grid;
        grid-template-columns: minmax(180px, 260px) minmax(0, 1fr);
        gap: 18px;
        align-items: center;
        margin: 24px 0 18px;
        padding: 18px 20px;
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
        background: var(--mud-palette-surface);
    }

    .overall-progress-bar,
    .course-progress-bar {
        height: 8px;
    }

    .courses-grid {
        align-items: stretch;
        margin-top: 20px;
    }

    .course-card {
        --course-accent: #64748b;
        --course-border: rgba(100, 116, 139, 0.42);
        --course-tint: rgba(100, 116, 139, 0.08);
        --course-icon-bg: rgba(100, 116, 139, 0.12);
        height: 100%;
        display: flex;
        flex-direction: column;
        gap: 18px;
        padding: 20px;
        border: 1px solid var(--course-border);
        border-left: 6px solid var(--course-accent);
        border-radius: 8px;
        background: linear-gradient(135deg, var(--course-tint) 0%, var(--mud-palette-surface) 44%, var(--mud-palette-surface) 100%);
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
        transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
    }

    .course-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 36px rgba(0, 0, 0, 0.12);
        border-color: var(--course-accent);
    }

    .course-card.not-started {
        --course-accent: #64748b;
        --course-border: rgba(100, 116, 139, 0.42);
        --course-tint: rgba(100, 116, 139, 0.08);
        --course-icon-bg: rgba(100, 116, 139, 0.12);
    }

    .course-card.in-progress {
        --course-accent: #b7791f;
        --course-border: rgba(183, 121, 31, 0.48);
        --course-tint: rgba(183, 121, 31, 0.1);
        --course-icon-bg: rgba(183, 121, 31, 0.14);
    }

    .course-card.completed {
        --course-accent: #2f7d5a;
        --course-border: rgba(47, 125, 90, 0.5);
        --course-tint: rgba(47, 125, 90, 0.1);
        --course-icon-bg: rgba(47, 125, 90, 0.14);
    }

    .course-card-header,
    .course-progress-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .course-card-chips {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 8px;
    }

    .course-icon-shell {
        width: 54px;
        height: 54px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        background: var(--course-icon-bg);
    }

    .course-card-body {
        min-height: 96px;
    }

    .course-card-title {
        font-weight: 800;
        line-height: 1.2;
    }

    .course-card-description {
        margin-top: 8px;
        color: var(--mud-palette-text-secondary);
    }

    .course-action {
        margin-top: auto;
    }

    .course-reset-action {
        margin-top: -8px;
    }

    @@media (max-width: 900px) {
        .courses-hero {
            grid-template-columns: 1fr;
        }

        .overall-progress {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 600px) {
        .courses-page {
            padding-top: 16px;
        }

        .courses-hero {
            padding: 20px;
        }

        .courses-summary {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthenticationState { get; set; } = default!;
    [Inject] private IUserService UserService { get; set; } = default!;
    [Inject] private IProjectService ProjectService { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private ApplicationUser? User { get; set; }
    private List<Course> CourseList { get; } = CourseHelper.GetCourses();
    private List<CourseCardInfo> DashboardCourses { get; set; } = new();

    private bool IsLoading = true;
    private bool IsLoggedIn;
    private bool IsResettingCourse;
    private string UserId = string.Empty;

    private int CompletedChapters => DashboardCourses.Sum(course => course.CompletedChapters);
    private int TotalChapters => DashboardCourses.Sum(course => course.TotalChapters);
    private int CompletedCourses => DashboardCourses.Count(course => course.Status == DashBoardCourseStatus.Completed);
    private int CoursesInProgress => DashboardCourses.Count(course => course.Status == DashBoardCourseStatus.InProgress);
    private double OverallProgress => TotalChapters == 0 ? 0 : Math.Round((double)CompletedChapters / TotalChapters * 100);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationState.GetAuthenticationStateAsync();

        IsLoggedIn = authState.User.Identity?.IsAuthenticated == true;

        if (IsLoggedIn)
        {
            UserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
            User = await UserService.GetUserById(UserId);
        }

        GetCourseInfo();

        IsLoading = false;
    }

    private void GetCourseInfo()
    {
        DashboardCourses = CourseList
            .Where(course => course.Articles.Count > 0)
            .Select(course =>
            {
                var articleIds = course.Articles.Select(article => article.Id).ToList();
                var completedCount = User is null
                    ? 0
                    : articleIds.Count(id =>
                        User.DashboardProjects.Any(project => project.IsCompleted && project.ProjectId == id));

                return new CourseCardInfo
                {
                    Id = course.Id,
                    Title = course.Title,
                    Description = course.Description,
                    ImgUrl = course.ImgUrl,
                    Level = course.Level,
                    CompletedChapters = completedCount,
                    TotalChapters = articleIds.Count,
                    Status = GetCourseStatus(completedCount, articleIds.Count)
                };
            })
            .ToList();
    }

    private void NavigateToCourse(int courseId)
    {
        var course = CourseList.Single(c => c.Id == courseId);
        var firstArticle = course.Articles.First();
        const bool isCode = false;

        Navigation.NavigateTo($"/course/{courseId}/article/{firstArticle.CourseDisplayId}/{firstArticle.Id}/{isCode}");
    }

    private async Task ConfirmResetCourse(int courseId)
    {
        var course = CourseList.Single(course => course.Id == courseId);
        var parameters = new DialogParameters
        {
            [nameof(TCSADeleteDialog.Title)] = "Reset course progress?",
            [nameof(TCSADeleteDialog.Message)] = $"Are you sure you want to reset {course.Title}? This will delete all chapter progress and remove the XP earned from this course. This can't be reversed.",
            [nameof(TCSADeleteDialog.ConfirmLabel)] = "Reset course"
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
        var dialog = await DialogService.ShowAsync<TCSADeleteDialog>("Reset course", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled)
        {
            return;
        }

        IsResettingCourse = true;
        var response = await ProjectService.ResetCourse(UserId, course);

        if (response.Status == Data.Models.Responses.ResponseStatus.Success)
        {
            User = await UserService.GetUserById(UserId);
            GetCourseInfo();
            Snackbar.Add("Course progress reset successfully.", Severity.Success);
        }
        else
        {
            Snackbar.Add(response.Message ?? "The course could not be reset.", Severity.Error);
        }

        IsResettingCourse = false;
    }

    private static DashBoardCourseStatus GetCourseStatus(int completedCount, int totalCount)
    {
        if (completedCount == 0)
        {
            return DashBoardCourseStatus.NotStarted;
        }

        return completedCount == totalCount
            ? DashBoardCourseStatus.Completed
            : DashBoardCourseStatus.InProgress;
    }

    private static Color GetStatusColor(DashBoardCourseStatus status)
    {
        return status switch
        {
            DashBoardCourseStatus.Completed => Color.Success,
            DashBoardCourseStatus.InProgress => Color.Primary,
            _ => Color.Default
        };
    }

    private static string GetStatusLabel(DashBoardCourseStatus status)
    {
        return status switch
        {
            DashBoardCourseStatus.Completed => "Completed",
            DashBoardCourseStatus.InProgress => "In Progress",
            _ => "Not Started"
        };
    }

    private static string GetActionLabel(DashBoardCourseStatus status)
    {
        return status == DashBoardCourseStatus.NotStarted ? "Start Course" : "Continue Course";
    }

    private static string GetLevelLabel(CourseLevel level)
    {
        return level switch
        {
            CourseLevel.Beginner => "Beginner",
            CourseLevel.Intermediate => "Intermediate",
            CourseLevel.Advanced => "Advanced",
            CourseLevel.Expert => "Expert",
            _ => level.ToString()
        };
    }

    private static Color GetLevelColor(CourseLevel level)
    {
        return level switch
        {
            CourseLevel.Beginner => Color.Success,
            CourseLevel.Intermediate => Color.Info,
            CourseLevel.Advanced => Color.Warning,
            CourseLevel.Expert => Color.Error,
            _ => Color.Default
        };
    }

    private static string GetCourseCardClass(DashBoardCourseStatus status)
    {
        return status switch
        {
            DashBoardCourseStatus.Completed => "course-card completed",
            DashBoardCourseStatus.InProgress => "course-card in-progress",
            _ => "course-card not-started"
        };
    }

    private sealed class CourseCardInfo
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string ImgUrl { get; set; } = string.Empty;
        public CourseLevel Level { get; set; }
        public int CompletedChapters { get; set; }
        public int TotalChapters { get; set; }
        public DashBoardCourseStatus Status { get; set; }
        public double ProgressPercent => TotalChapters == 0 ? 0 : Math.Round((double)CompletedChapters / TotalChapters * 100);
        public string ChapterLabel => TotalChapters == 1 ? "chapter" : "chapters";
    }
}
