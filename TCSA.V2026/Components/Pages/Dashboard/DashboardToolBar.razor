@using TCSA.V2026.Components.UI
@using TCSA.V2026.Data.Curriculum
@using TCSA.V2026.Data.DTOs
@using TCSA.V2026.Data.Enums
@using TCSA.V2026.Data.Models
@using TCSA.V2026.Data.Models.Responses
@using TCSA.V2026.Helpers
@using TCSA.V2026.Services

@inject IDialogService DialogService

<MudPaper Class="user-summary-card" Elevation="0">
    <div class="user-summary-main">
        <div class="user-identity">
            <MudImage Class="user-country-flag"
                      Src="@FlagHelper.GetFlag(User.Country)"
                      Alt="@($"{User.Country} flag")" />
            <div class="user-copy">
                <MudText Typo="Typo.h5" Class="user-name">
                    @UserDisplayNameHelper.GetDisplayName(User.DisplayName, User.UserName)
                </MudText>
            </div>
        </div>

        <div class="user-stats">
            <div class="user-stat user-belt-stat">
                <MudImage Src="@($"img/belts/{(Level)User.Level}-belt.png")"
                          Alt="@($"{FormatLevel((Level)User.Level)} belt")"
                          Class="user-stat-icon" />
                <div>
                    <MudText Typo="Typo.subtitle1" Class="user-stat-value">@FormatLevel((Level)User.Level)</MudText>
                </div>
            </div>

            <div class="user-stat">
                <MudImage Src="img/experience.png" Alt="Experience points" Class="user-stat-icon" />
                <div>
                    <MudText Typo="Typo.subtitle1"
                             Class="user-stat-value"
                             UserAttributes="@(new() { { "data-testid", "user-xp" } })">
                        @User.ExperiencePoints XP
                    </MudText>
                </div>
            </div>
        </div>

        <div class="user-notifications">
            @if (Notifications.Any(x => x.IsActive))
            {
                <MudBadge Content="@Notifications.Count(x => x.IsActive)" Overlap="true" Color="Color.Error">
                    <MudIconButton OnClick="OpenDialog"
                                   Icon="@Icons.Material.Filled.Notifications"
                                   Color="Color.Primary"
                                   Class="notification-button"
                                   aria-label="Open notifications" />
                </MudBadge>
            }
            else
            {
                <MudIconButton OnClick="OpenDialog"
                               Icon="@Icons.Material.Filled.NotificationsNone"
                               Color="Color.Primary"
                               Class="notification-button"
                               aria-label="Open notifications" />
            }
        </div>
    </div>
</MudPaper>


@code {
    [Inject] private NavigationManager Navigation { get; set; }
    [Parameter] public ApplicationUser User { get; set; }
    [Inject] private IProjectService ProjectService { get; set; }
    [Inject] private IUserService UserService { get; set; }

    private List<TCSANotificationItem> Notifications = new();

    private static string FormatLevel(Level level) => level == Level.OliveGreen ? "Olive Green Belt" : $"{level} Belt";

    protected async override Task OnParametersSetAsync()
    {
        var projects = ProjectHelper.GetProjects();

        var dbProjects = User.DashboardProjects.Where(dp => dp.DateCompleted > DateTime.UtcNow.AddDays(-7));

        foreach(var project in dbProjects)
        {
            var curriculumProject = projects.FirstOrDefault(p => p.Id == project.ProjectId);

            if (curriculumProject != null)
            {
                var description = GetDescription(project.ProjectId);
                var isDupe = Notifications.Any(x => description.Equals(x.Description));

                if (!isDupe)
                {
                    Notifications.Add(
                        new TCSANotificationItem
                        {
                            IconUrl = curriculumProject.IconUrl,
                            Description = description,
                            IsActive = project.IsPendingNotification
                        }
                    );   
                };
            }
        }

        if (User.UserActivity.Any(x => x.ActivityType == ActivityType.NewBelt && x.DateSubmitted >= DateTime.UtcNow.AddDays(-7)))
        {
            var description = $"You achieved {User.Level} belt!";
            var isDupe = Notifications.Any(x => description.Equals(x.Description));

            if (!isDupe)
            {
                Notifications.Add(new TCSANotificationItem
                {
                    IconUrl = $"{(Level)User.Level}-belt.png",
                    Description = $"You achieved {User.Level} belt!",
                    IsActive = User.HasPendingBeltNotification
                });
            }
        }
    }

    private string GetDescription(int projectId)
    {
        var project = ProjectHelper.GetProjects().FirstOrDefault(x => x.Id == projectId);
        return $"Your project {project.Title} was marked as completed!"; 
    }

    private async Task OpenDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters<TCSANotificationDialog>
        {
            { p => p.Notifications, Notifications }
        };
        var dialog = await DialogService.ShowAsync<TCSANotificationDialog>("Your notifications for the past 7 days", parameters, options);

        var result = await dialog.Result;

        if (!result.Canceled && Notifications.Any(x => x.IsActive))
        {
            var acknowledgeProjectsTask = ProjectService.AcknowledgeNotifications(User.Id);
            var acknowledgeBeltTask = UserService.AcknowledgeBeltNotification(User.Id);

            await Task.WhenAll(acknowledgeProjectsTask, acknowledgeBeltTask);

            var acknowledgeProjectsResponse = await acknowledgeProjectsTask;
            var acknowledgeBeltResponse = await acknowledgeBeltTask;

            if (acknowledgeProjectsResponse.Status == ResponseStatus.Success && acknowledgeBeltResponse.Status == ResponseStatus.Success)
            {
                Notifications.ForEach(x => x.IsActive = false);
                StateHasChanged();
            }
        }
    }
}

<style>
    .user-summary-card {
        margin-top: 1.5rem;
        padding: 1.15rem 1.35rem;
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.18);
        border-radius: 18px;
        background: linear-gradient(135deg, rgba(var(--mud-palette-primary-rgb), 0.08), var(--mud-palette-surface) 48%, rgba(var(--mud-palette-secondary-rgb), 0.06));
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    }

    .user-summary-main,
    .user-identity,
    .user-stats,
    .user-stat {
        display: flex;
        align-items: center;
    }

    .user-summary-main {
        gap: 1.5rem;
    }

    .user-identity {
        gap: 0.9rem;
        min-width: 0;
    }

    .user-country-flag {
        width: 54px;
        height: 38px;
        border-radius: 8px;
        object-fit: cover;
        box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.12);
    }

    .user-copy {
        min-width: 0;
    }

    .user-eyebrow,
    .user-stat-label {
        color: var(--mud-palette-text-secondary);
        letter-spacing: 0.055em;
    }

    .user-name {
        font-weight: 750;
        line-height: 1.2;
        overflow-wrap: anywhere;
    }

    .user-stats {
        gap: 0.75rem;
        margin-left: auto;
    }

    .user-stat {
        gap: 0.7rem;
        min-width: 150px;
        padding: 0.65rem 0.85rem;
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 12px;
        background: color-mix(in srgb, var(--mud-palette-surface) 92%, var(--mud-palette-primary) 8%);
    }

    .user-stat-icon {
        width: 34px;
        height: 34px;
        object-fit: contain;
    }

    .user-stat-value {
        font-weight: 700;
        line-height: 1.25;
    }

    .user-notifications {
        padding-left: 0.25rem;
    }

    .notification-button {
        background: rgba(var(--mud-palette-primary-rgb), 0.1);
    }

    @@media (max-width: 800px) {
        .user-summary-main {
            align-items: stretch;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .user-identity {
            flex: 1 1 calc(100% - 56px);
        }

        .user-stats {
            order: 3;
            width: 100%;
            margin-left: 0;
        }

        .user-stat {
            flex: 1 1 0;
            min-width: 0;
        }

        .user-notifications {
            margin-left: auto;
        }
    }

    @@media (max-width: 480px) {
        .user-summary-card {
            padding: 1rem;
        }

        .user-stats {
            flex-direction: column;
        }

        .user-stat {
            width: 100%;
        }
    }
</style>
