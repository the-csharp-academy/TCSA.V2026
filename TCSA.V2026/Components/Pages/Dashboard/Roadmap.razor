@page "/dashboard/roadmap"
@using Microsoft.AspNetCore.Authorization

@using System.Security.Claims;
@using TCSA.V2026.Components.Ads
@using TCSA.V2026.Components.UI
@using TCSA.V2026.Data.Enums
@using TCSA.V2026.Data.Models
@using TCSA.V2026.Helpers
@using TCSA.V2026.Services
@using TCSA.V2026.Data.DTOs;
@attribute [Authorize]

<PageTitle>Roadmap</PageTitle>
<MudContainer MaxWidth="MaxWidth.Large" Class="roadmap-page">
    @if (User != null)
    {
        <DashboardToolBar User=@User></DashboardToolBar>
    }

    <MudGrid Spacing="4" Class="roadmap-layout">
        <MudItem xs="12" md="9">
            @if (IsLoading)
            {
                <div class="roadmap-loading">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    <MudText Typo="Typo.body2">Building your roadmap...</MudText>
                </div>
            }
            else
            {
                if (RoadmapResult.MissingTasksForNextBelt.Count > 0)
                {
                    <MudCard Class="next-belt-card" Elevation="0">
                        <MudCardContent Class="next-belt-content">
                            <div class="next-belt-header">
                                <div>
                                    <MudText Typo="Typo.overline" Class="roadmap-kicker">Next milestone</MudText>
                                    <MudText Typo="Typo.h5" Class="next-belt-title">Your path to @GetNextBeltName()</MudText>
                                    <MudText Typo="Typo.body2" Class="roadmap-subtitle">
                                        @RoadmapResult.MissingTasksForNextBelt.Count remaining @(RoadmapResult.MissingTasksForNextBelt.Count == 1 ? "task" : "tasks")
                                    </MudText>
                                </div>
                                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Class="next-belt-trophy" />
                            </div>
                            <div class="next-belt-tasks">
                                @foreach (var task in RoadmapResult.MissingTasksForNextBelt)
                                {
                                    <MudTooltip Text="@task.Tooltip">
                                        <div class="next-belt-task">
                                            <MudImage Src="@($"/img/icons/{task.IconUrl}")" Alt="@task.Name" />
                                        </div>
                                    </MudTooltip>
                                }
                            </div>
                        </MudCardContent>
                    </MudCard>
                }
                if (RoadmapResult.Stages.Count > 0)
                {
                    <MudTimeline TimelinePosition="TimelinePosition.Start" Class="belt-timeline">
                        @for (int stageIndex = 0; stageIndex < RoadmapResult.Stages.Count; stageIndex++)
                        {
                            var stage = RoadmapResult.Stages[stageIndex];
                            <MudTimelineItem Size="Size.Large"
                                             Class="@($"{stage.Class}")"
                                             Variant="Variant.Outlined"
                                             Elevation="1">
                                <TCSARoadmapCard Tasks="stage.Tasks"
                                                 StageName="@GetStageName(stage.Class)"
                                                 StageClass="@stage.Class" />
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                }
            }
        </MudItem>

        <MudItem xs="12" md="3" Class="roadmap-ad-column">
            <aside class="roadmap-ad-rail" aria-label="Advertisement">
                <div class="roadmap-sidebar-ad">
                    <AdSenseAd Slot="3513304362" />
                </div>
            </aside>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [Inject] private AuthenticationStateProvider AuthenticationState { get; set; }
    [Inject] private NavigationManager NavigationManager { get; set; }
    [Inject] private IUserService UserService { get; set; }

    private ApplicationUser User { get; set; }
    private int ReviewsCount = 0;
    private int IssuesCount = 0;
    private bool IsLoading = true;
    private string UserId = string.Empty;
    private TimeSpan LoadTime = TimeSpan.Zero;
    private Level UserLevel { get; set; }

    public static List<int> CompletedProjects = new();

    public static RoadmapResult RoadmapResult = new();

    private static readonly string[] StageNames =
    [
        "Green Belt", "Olive Green Belt", "Yellow Belt", "Orange Belt", "Red Belt",
        "Purple Belt", "Brown Belt", "Grey Belt", "Blue Belt", "Black Belt"
    ];

    private static string GetStageName(string stageClass) => stageClass switch
    {
        "custom-color-green" => "Green Belt",
        "custom-color-olivegreen" => "Olive Green Belt",
        "custom-color-yellow" => "Yellow Belt",
        "custom-color-orange" => "Orange Belt",
        "custom-color-red" => "Red Belt",
        "custom-color-purple" => "Purple Belt",
        "custom-color-brown" => "Brown Belt",
        "custom-color-gray" => "Grey Belt",
        "custom-color-blue" => "Blue Belt",
        "custom-color-black" => "Black Belt",
        _ => "Belt"
    };

    private string GetNextBeltName()
    {
        int nextStageIndex = Math.Clamp((int)User.Level - 1, 0, StageNames.Length - 1);
        return StageNames[nextStageIndex];
    }

    protected override async Task OnInitializedAsync()
    {
        var startTime = DateTime.UtcNow;
        var AuthSate = await AuthenticationState.GetAuthenticationStateAsync();

        if (!AuthSate.User.Identity.IsAuthenticated)
        {
            NavigationManager.NavigateTo("Account/Login");
        }

        var claims = AuthSate.User;
        UserId = claims.FindFirstValue(ClaimTypes.NameIdentifier);
        User = await UserService.GetDetailedUserById(UserId);
        CompletedProjects = User.DashboardProjects.Where(p => p.IsCompleted).Select(p => p.ProjectId).ToList();

        ReviewsCount = User.CodeReviewProjects != null
        ? User.CodeReviewProjects.Where(x => x.DashboardProject.IsCompleted).Count()
        : 0;

        IssuesCount = User.Issues != null ? User.Issues.Count(x => x.IsClosed) : 0;

        RoadmapResult = RoadmapHelper.GetRoadmap(User.Level, CompletedProjects, ReviewsCount, IssuesCount);
        LoadTime = DateTime.UtcNow - startTime;
        IsLoading = false;
    }
}

<style>
    .roadmap-page {
        padding-bottom: 4rem;
    }

    .roadmap-layout {
        align-items: stretch;
        margin-top: 0;
    }

    .roadmap-ad-column {
        align-self: stretch;
        position: relative;
    }

    .roadmap-ad-rail {
        width: 100%;
        min-width: 0;
        padding: 2rem 0;
    }

    .roadmap-sidebar-ad {
        width: 100%;
        max-width: 300px;
        min-width: 0;
        min-height: 600px;
        margin-left: auto;
        overflow: hidden;
    }

    /* AdSense permits vertical sticky units on desktop when they remain within
       their content rail, never overlap the page, and are no wider than 300px. */
    @@media (min-width: 1200px) and (min-height: 720px) {
        .roadmap-ad-rail {
            position: sticky;
            top: 92px;
        }
    }

    .roadmap-heading {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1.5rem;
        margin: 2rem 0 1.25rem;
    }

    .roadmap-kicker {
        color: var(--mud-palette-primary);
        font-weight: 700;
        letter-spacing: 0.08em;
    }

    .roadmap-title,
    .next-belt-title {
        font-weight: 800;
        letter-spacing: -0.025em;
    }

    .roadmap-subtitle {
        max-width: 700px;
        color: var(--mud-palette-text-secondary);
        line-height: 1.65;
    }

    .roadmap-summary-pill {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        flex: 0 0 auto;
        padding: 0.65rem 0.9rem;
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.2);
        border-radius: 999px;
        background: rgba(var(--mud-palette-primary-rgb), 0.07);
        font-weight: 650;
    }

    .roadmap-loading {
        min-height: 280px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 1rem;
    }

    .next-belt-card {
        margin-bottom: 1.5rem;
        overflow: hidden;
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.22);
        border-radius: 18px;
        background: linear-gradient(125deg, rgba(var(--mud-palette-primary-rgb), 0.11), var(--mud-palette-surface) 55%, rgba(var(--mud-palette-secondary-rgb), 0.09));
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.07);
    }

    .next-belt-content {
        padding: 1.15rem 1.3rem !important;
    }

    .next-belt-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .next-belt-trophy {
        color: #d79512;
        font-size: 3rem;
        opacity: 0.9;
    }

    .next-belt-tasks {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        margin-top: 0.9rem;
        padding-top: 0.9rem;
        border-top: 1px solid var(--mud-palette-lines-default);
    }

    .next-belt-task {
        width: 78px;
        height: 78px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.65rem;
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 50%;
        background: var(--mud-palette-surface);
        transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
    }

    .next-belt-task:hover {
        transform: translateY(-2px);
        border-color: rgba(var(--mud-palette-primary-rgb), 0.45);
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.1);
    }

    .next-belt-task img {
        width: 46px;
        height: 46px;
        object-fit: contain;
    }

    .belt-timeline {
        margin-top: 0.5rem;
    }

        .belt-timeline .mud-timeline-item-content {
            width: 100%;
            padding-bottom: 1.35rem;
        }

    .custom-color-green .mud-timeline-item-dot .mud-timeline-item-dot-inner {
        background-color: #15803d !important;
        border-color: #15803d !important;
    }

    .custom-color-olivegreen .mud-timeline-item-dot .mud-timeline-item-dot-inner {
        background-color: darkolivegreen !important;
        border-color: darkolivegreen !important;
    }

    .custom-color-yellow .mud-timeline-item-dot .mud-timeline-item-dot-inner {
        background-color: #c58b00 !important;
        border-color: #c58b00 !important;
    }

    .custom-color-orange .mud-timeline-item-dot .mud-timeline-item-dot-inner {
        background-color: #FF6600 !important;
        border-color: #FF6600 !important;
    }

    .custom-color-red .mud-timeline-item-dot .mud-timeline-item-dot-inner {
        background-color: #cf3f46 !important;
        border-color: #cf3f46 !important;
    }

    .custom-color-purple .mud-timeline-item-dot .mud-timeline-item-dot-inner {
        background-color: purple !important;
        border-color: purple !important;
    }

    .custom-color-brown .mud-timeline-item-dot .mud-timeline-item-dot-inner {
        background-color: saddlebrown !important;
        border-color: saddlebrown !important;
    }

    .custom-color-gray .mud-timeline-item-dot .mud-timeline-item-dot-inner {
        background-color: dimgray !important;
        border-color: dimgray !important;
    }

    .custom-color-blue .mud-timeline-item-dot .mud-timeline-item-dot-inner {
        background-color: #2563b8 !important;
        border-color: #2563b8 !important;
    }

    .custom-color-black .mud-timeline-item-dot .mud-timeline-item-dot-inner {
        background-color: #252936 !important;
        border-color: #252936 !important;
    }

    @@media (max-width: 960px) {
        .roadmap-ad-rail {
            padding: 1rem 0;
        }

        .roadmap-sidebar-ad {
            min-height: 250px;
        }
    }

    @@media (max-width: 700px) {
        .roadmap-heading {
            align-items: flex-start;
            flex-direction: column;
            margin-top: 1.5rem;
        }

        .roadmap-title {
            font-size: 2rem;
        }

        .roadmap-summary-pill {
            align-self: flex-start;
        }

        .next-belt-content {
            padding: 1.15rem !important;
        }

        .next-belt-task {
            width: 70px;
            height: 70px;
        }
    }
</style>

