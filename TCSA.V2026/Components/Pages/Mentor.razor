@page "/mentorship/mentor"
@using Microsoft.Extensions.Options
@using TCSA.V2026.Data.Models.Options
@inject IOptions<LinksOptions> LinkOptions

<PageTitle>Meet Your Mentor - The C# Academy</PageTitle>

<div class="mentor-page">
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-10">
        <MudPaper Class="mentor-hero pa-8 pa-md-12" Elevation="8">
            <MudGrid Spacing="4" Class="mentor-hero-grid">
                <MudItem xs="12" md="7">
                    <MudChip T="string" Class="mentor-chip mb-4" Variant="Variant.Filled">
                        Meet your mentor
                    </MudChip>
                    <MudText Typo="Typo.h2" Class="mentor-title mb-4">
                        Hi, I'm Pablo.
                    </MudText>
                    <MudText Typo="Typo.h6" Class="mentor-subtitle mb-6">
                        I'm a software developer based in Brisbane, Australia, with 7 years of coding behind me and 5 years of professional experience building real systems for real teams.
                    </MudText>
                    <MudStack Row="true" Spacing="2" Class="mentor-actions" AlignItems="AlignItems.Center">
                        <MudButton Variant="Variant.Filled"
                                   Class="linkedin-button"
                                   StartIcon="@Icons.Custom.Brands.LinkedIn"
                                   Href="@LinkedinUrl"
                                   Target="_blank"
                                   Disabled="@string.IsNullOrWhiteSpace(LinkedinUrl)">
                            LinkedIn
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Class="back-button"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   Href="/mentorship">
                            Back to Mentorship
                        </MudButton>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" md="5">
                    <div class="mentor-profile-card">
                        <div class="mentor-avatar">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Class="mentor-avatar-icon"></MudIcon>
                        </div>
                        <MudText Typo="Typo.h5" Class="mentor-name">Pablo</MudText>
                        <MudText Typo="Typo.body1" Class="mentor-location">
                            Brisbane, Australia
                        </MudText>
                        <div class="mentor-tags">
                            <span>C#</span>
                            <span>Mentorship</span>
                            <span>Career growth</span>
                        </div>
                    </div>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="mentor-guarantee-panel pa-6 mt-8" Elevation="6">
            <div class="mentor-guarantee-icon-wrap">
                <MudIcon Icon="@Icons.Material.Filled.Savings" Class="mentor-guarantee-icon"></MudIcon>
            </div>
            <div>
                <MudText Typo="Typo.h4" Class="mentor-guarantee-title mb-2">
                    Money Back Guarantee
                </MudText>
                <MudText Typo="Typo.body1" Class="mentor-guarantee-copy">
                    If you do not see results in your first month, you get your money back. The goal is simple: visible progress, better code, and a clearer path forward.
                </MudText>
            </div>
        </MudPaper>

        <MudGrid Spacing="3" Class="mt-8">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="mentor-stat stat-coral" Elevation="4">
                    <MudIcon Icon="@Icons.Material.Filled.Code" Class="stat-icon"></MudIcon>
                    <MudText Typo="Typo.h4" Class="stat-number">7</MudText>
                    <MudText Typo="Typo.body2">years coding</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="mentor-stat stat-blue" Elevation="4">
                    <MudIcon Icon="@Icons.Material.Filled.Work" Class="stat-icon"></MudIcon>
                    <MudText Typo="Typo.h4" Class="stat-number">5</MudText>
                    <MudText Typo="Typo.body2">years professional</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="mentor-stat stat-green" Elevation="4">
                    <MudIcon Icon="@Icons.Material.Filled.Storefront" Class="stat-icon"></MudIcon>
                    <MudText Typo="Typo.h4" Class="stat-number">1</MudText>
                    <MudText Typo="Typo.body2">year at EB Games</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="mentor-stat stat-gold" Elevation="4">
                    <MudIcon Icon="@Icons.Material.Filled.BusinessCenter" Class="stat-icon"></MudIcon>
                    <MudText Typo="Typo.h4" Class="stat-number">4</MudText>
                    <MudText Typo="Typo.body2">years at Business Automation Works</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudGrid Spacing="4" Class="mt-8">
            <MudItem xs="12" md="6">
                <MudPaper Class="mentor-panel pa-6" Elevation="5">
                    <MudText Typo="Typo.h5" Class="section-title mb-4">Where I've Worked</MudText>
                    <div class="timeline">
                        <div class="timeline-item">
                            <span class="timeline-dot dot-green"></span>
                            <div>
                                <MudText Typo="Typo.h6">EB Games</MudText>
                                <MudText Typo="Typo.body2">1 year of professional coding experience in a fast-moving retail technology environment.</MudText>
                            </div>
                        </div>
                        <div class="timeline-item">
                            <span class="timeline-dot dot-blue"></span>
                            <div>
                                <MudText Typo="Typo.h6">Business Automation Works</MudText>
                                <MudText Typo="Typo.body2">4 years building, maintaining, and improving business software with practical outcomes in mind.</MudText>
                            </div>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="mentor-panel pa-6 mentor-style-panel" Elevation="5">
                    <MudText Typo="Typo.h5" Class="section-title mb-4">How I Mentor</MudText>
                    <MudText Typo="Typo.body1" Class="mb-4">
                        My goal is to make programming feel less mysterious and more manageable. We'll focus on practical code, clear next steps, and the habits that help you keep improving after each session.
                    </MudText>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <div class="mentor-principle">
                                <MudIcon Icon="@Icons.Material.Filled.Route" />
                                <span>Clear learning path</span>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <div class="mentor-principle">
                                <MudIcon Icon="@Icons.Material.Filled.RateReview" />
                                <span>Helpful code reviews</span>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <div class="mentor-principle">
                                <MudIcon Icon="@Icons.Material.Filled.Psychology" />
                                <span>Problem-solving practice</span>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <div class="mentor-principle">
                                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" />
                                <span>Career-minded guidance</span>
                            </div>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
</div>

<style>
    .mentor-page {
        min-height: 100vh;
        background:
            radial-gradient(circle at 12% 18%, rgba(255, 112, 154, 0.22), transparent 30%),
            radial-gradient(circle at 88% 12%, rgba(56, 239, 125, 0.18), transparent 28%),
            linear-gradient(135deg, #f7fbff 0%, #edf6f9 46%, #fff8e7 100%);
        padding-bottom: 24px;
    }

    .mentor-hero {
        border-radius: 12px;
        color: white;
        background: linear-gradient(135deg, #1c236d 0%, #c9436e 54%, #f2b84b 100%) !important;
        overflow: hidden;
        position: relative;
    }

    .mentor-hero::after {
        content: "";
        position: absolute;
        width: 320px;
        height: 320px;
        right: -80px;
        bottom: -120px;
        border-radius: 50%;
        border: 48px solid rgba(255, 255, 255, 0.12);
    }

    .mentor-hero > .mud-grid {
        position: relative;
        z-index: 1;
    }

    .mentor-hero-grid {
        align-items: center;
    }

    .mentor-chip {
        width: fit-content;
        background: rgba(255, 255, 255, 0.18) !important;
        color: white !important;
        font-weight: 700;
    }

    .mentor-title {
        color: white;
        font-weight: 800 !important;
        line-height: 1.05;
    }

    .mentor-subtitle {
        color: white;
        line-height: 1.55;
        max-width: 720px;
    }

    .mentor-actions {
        flex-wrap: wrap;
    }

    .linkedin-button {
        background: #0a66c2 !important;
        color: white !important;
        font-weight: 700;
    }

    .back-button {
        color: white !important;
        border-color: rgba(255, 255, 255, 0.75) !important;
    }

    .mentor-profile-card {
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.16);
        border: 1px solid rgba(255, 255, 255, 0.28);
        backdrop-filter: blur(12px);
        padding: 32px;
        text-align: center;
    }

    .mentor-avatar {
        width: 128px;
        height: 128px;
        border-radius: 50%;
        margin: 0 auto 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #38ef7d 0%, #fee140 100%);
        box-shadow: 0 18px 36px rgba(28, 35, 109, 0.25);
    }

    .mentor-avatar-icon {
        color: #1c236d;
        font-size: 76px;
    }

    .mentor-name {
        color: white;
        font-weight: 800 !important;
    }

    .mentor-location {
        color: rgba(255, 255, 255, 0.86);
    }

    .mentor-tags {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px;
        margin-top: 20px;
    }

    .mentor-tags span {
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.18);
        color: white;
        font-size: 0.85rem;
        font-weight: 700;
        padding: 6px 12px;
    }

    .mentor-stat {
        min-height: 178px;
        border-radius: 12px;
        color: white;
        padding: 24px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .stat-coral {
        background: linear-gradient(135deg, #ff6f61 0%, #c9436e 100%) !important;
    }

    .stat-blue {
        background: linear-gradient(135deg, #1c236d 0%, #2f80ed 100%) !important;
    }

    .stat-green {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%) !important;
    }

    .stat-gold {
        background: linear-gradient(135deg, #f2994a 0%, #f2c94c 100%) !important;
    }

    .stat-icon {
        font-size: 34px;
        color: white;
    }

    .stat-number {
        color: white;
        font-weight: 900 !important;
        line-height: 1;
    }

    .mentor-stat .mud-typography-body2 {
        color: rgba(255, 255, 255, 0.92);
        font-weight: 700;
    }

    .mentor-panel {
        height: 100%;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.94) !important;
        border: 1px solid rgba(28, 35, 109, 0.08);
    }

    .mentor-guarantee-panel {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 20px;
        align-items: center;
        border-radius: 12px;
        background: linear-gradient(135deg, #fff7db 0%, #ffffff 100%) !important;
        border: 2px solid rgba(242, 201, 76, 0.65);
    }

    .mentor-guarantee-icon-wrap {
        width: 76px;
        height: 76px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f2c94c;
        box-shadow: 0 14px 28px rgba(242, 201, 76, 0.24);
    }

    .mentor-guarantee-icon {
        color: #1c236d;
        font-size: 42px;
    }

    .mentor-guarantee-title {
        color: #1c236d;
        font-weight: 800 !important;
    }

    .mentor-guarantee-copy {
        color: #5b6475;
        line-height: 1.65;
        max-width: 820px;
    }

    .section-title {
        color: #1c236d;
        font-weight: 800 !important;
    }

    .timeline {
        display: grid;
        gap: 22px;
    }

    .timeline-item {
        display: grid;
        grid-template-columns: 22px 1fr;
        gap: 14px;
        align-items: start;
    }

    .timeline-dot {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        margin-top: 6px;
        box-shadow: 0 0 0 6px rgba(28, 35, 109, 0.08);
    }

    .dot-green {
        background: #11998e;
    }

    .dot-blue {
        background: #2f80ed;
    }

    .timeline-item .mud-typography-h6 {
        color: #273043;
        font-weight: 800;
    }

    .timeline-item .mud-typography-body2,
    .mentor-style-panel .mud-typography-body1 {
        color: #5b6475;
        line-height: 1.6;
    }

    .mentor-principle {
        min-height: 58px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-radius: 10px;
        background: #f7fbff;
        border: 1px solid #dce9f5;
        padding: 12px;
        color: #1c236d;
        font-weight: 700;
    }

    .mentor-principle .mud-icon-root {
        color: #c9436e;
        flex: 0 0 auto;
    }

    @@media (max-width: 600px) {
        .mentor-title {
            font-size: 2.4rem !important;
        }

        .mentor-hero {
            padding: 32px 24px !important;
        }

        .mentor-profile-card {
            padding: 24px;
        }

        .mentor-guarantee-panel {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private string LinkedinUrl => LinkOptions.Value.Linkedin;
}
